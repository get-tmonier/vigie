{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**", ".output/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "check": {},
    "check:fix": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "test:unit": {},
    "test:integration": {},
    "knip": {}
  }
}
