{
  "name": "@tmonier/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#contracts/*": "./src/contracts/*",
    "#schemas/*": "./src/schemas/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "biome lint ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check-imports": "bun ../../scripts/check-imports.ts",
    "fix-imports": "bun ../../scripts/fix-imports.ts"
  },
  "dependencies": {
    "@ts-rest/core": "3.52.1",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
