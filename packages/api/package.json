{
  "name": "@tmonier/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#database/*": "./src/database/*",
    "#modules/*": "./src/modules/*",
    "#routes/*": "./src/routes/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --env-file=../../.env --env-file=../../.env.local --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun scripts/test-filter.ts unit",
    "test:integration": "bun scripts/test-filter.ts integration",
    "migrate": "env $(cat ../../.env ../../.env.local 2>/dev/null | grep -v '^#' | xargs) bunx @better-auth/cli migrate",
    "check-imports": "bun ../../scripts/check-imports.ts",
    "fix-imports": "bun ../../scripts/fix-imports.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "1.5.1",
    "@tmonier/shared": "workspace:*",
"better-auth": "1.5.1",
    "effect": "4.0.0-beta.21",
    "hono": "4.12.3",
    "pg": "8.19.0",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "typescript": "5.9.3"
  }
}
