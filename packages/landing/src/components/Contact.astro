---
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
  locale: string;
}

const { content, locale } = Astro.props;
const { contact } = content;
const contactHref = locale === 'fr' ? '/fr/contact' : '/contact';
---

<section id="contact" class="bg-navy-deep py-20 px-10 min-h-[calc(100vh-64px)] box-border flex flex-col justify-center max-md:py-12 max-md:px-5 max-md:min-h-[calc(100svh-64px)]">
  <div class="max-w-[600px] mx-auto text-center">
    <p class="reveal-up font-mono text-gold-dark text-[0.75rem] tracking-[0.15em] uppercase m-0 mb-4" style="--delay: 0ms">
      {contact.label}
    </p>
    <h2 class="reveal-up font-bitter text-cream font-bold text-[clamp(1.8rem,4vw,2.8rem)] m-0 mb-6 leading-[1.2]" style="--delay: 80ms">
      {contact.title}
    </h2>

    <div class="reveal-scale inline-block font-mono text-[0.75rem] text-gold bg-gold/10 border border-gold/25 rounded-[20px] py-[0.4rem] px-4 mb-8" style="--delay: 160ms">
      {contact.availability}
    </div>

    <div class="reveal-up flex flex-col items-center gap-3 mb-8" style="--delay: 240ms">
      <a
        href={`mailto:${contact.email}`}
        class="font-mono text-slate text-[0.82rem] no-underline hover:text-gold transition-colors duration-200"
      >
        {contact.email}
      </a>
      <a
        href={`tel:${contact.phone.replace(/\s/g, '')}`}
        class="font-mono text-slate text-[0.82rem] no-underline hover:text-gold transition-colors duration-200"
      >
        {contact.phone}
      </a>
    </div>

    <div class="reveal-up flex justify-center gap-5 mb-10" style="--delay: 320ms">
      <a
        href="https://www.linkedin.com/in/damien-meur/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate hover:text-gold transition-colors duration-200"
        aria-label="LinkedIn"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://github.com/get-tmonier"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate hover:text-gold transition-colors duration-200"
        aria-label="GitHub"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
    </div>

    <div class="reveal-scale" style="--delay: 400ms">
      <a
        href={contactHref}
        class="font-mono bg-gold text-navy-deep font-semibold text-sm py-[0.85rem] px-[1.8rem] rounded-[4px] no-underline transition-colors duration-200 inline-block hover:bg-gold-light"
      >
        {contact.cta}
      </a>
    </div>
  </div>
</section>
