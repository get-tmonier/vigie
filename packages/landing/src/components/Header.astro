---
import RadarMark from '#components/RadarMark.astro';
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
  locale: string;
}
const { content, locale } = Astro.props;
const { nav } = content;
---

<header class="fixed top-0 left-0 right-0 z-40 bg-navy-900/80 backdrop-blur-md border-b border-navy-700/50">
  <div class="max-w-[1200px] mx-auto flex items-center justify-between py-3 px-6">
    <!-- Tmonier | vigie lockup (brand guide §05) -->
    <a href="/" class="flex items-center gap-[10px] no-underline">
      <!-- Tmonier helm mark (exact original geometry) -->
      <svg width="22" height="22" viewBox="0 0 64 64" overflow="visible" aria-hidden="true">
        <defs>
          <linearGradient id="header-brass" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#D4AA3C" />
            <stop offset="45%" stop-color="#C49A2B" />
            <stop offset="100%" stop-color="#A67C1A" />
          </linearGradient>
        </defs>
        <path d="M32.0,24.0 L32.0,10.0 M37.7,26.3 L47.6,16.4 M40.0,32.0 L54.0,32.0 M37.7,37.7 L47.6,47.6 M32.0,40.0 L32.0,54.0 M26.3,37.7 L16.4,47.6 M24.0,32.0 L10.0,32.0 M26.3,26.3 L16.4,16.4" fill="none" stroke="url(#header-brass)" stroke-width="2" stroke-linecap="round" />
        <circle cx="32" cy="32" r="22" fill="none" stroke="url(#header-brass)" stroke-width="3" />
        <circle cx="32" cy="32" r="12" fill="none" stroke="url(#header-brass)" stroke-width="2" />
        <circle cx="32" cy="32" r="6.5" fill="none" stroke="url(#header-brass)" stroke-width="1.5" />
        <circle cx="32" cy="32" r="3" fill="url(#header-brass)" />
        <path d="M32.0,13.0 L32.0,1.0 M45.4,18.6 L53.9,10.1 M51.0,32.0 L63.0,32.0 M45.4,45.4 L53.9,53.9 M32.0,51.0 L32.0,63.0 M18.6,45.4 L10.1,53.9 M13.0,32.0 L1.0,32.0 M18.6,18.6 L10.1,10.1" fill="none" stroke="url(#header-brass)" stroke-width="4" stroke-linecap="round" />
      </svg>
      <span class="font-display text-[1rem] text-brass-400">Tmonier</span>
      <span class="text-cream-200/30">|</span>
      <span class="font-display text-[1.2rem] text-vigie-400">vigie</span>
    </a>

    <!-- Nav -->
    <nav class="flex items-center gap-6 max-md:gap-4">
      <a href="#dashboard-demo" class="font-body text-[0.8rem] text-cream-200 no-underline hover:text-cream-50 transition-all duration-150">{nav.demo}</a>
      <a href="#open-source" class="font-body text-[0.8rem] text-cream-200 no-underline hover:text-cream-50 transition-all duration-150">{nav.openSource}</a>
      <a href={locale === 'fr' ? '/fr/faq' : '/faq'} class="font-body text-[0.8rem] text-cream-200 no-underline hover:text-cream-50 transition-all duration-150">{nav.faq}</a>
      <div class="flex items-center bg-navy-800/50 rounded-[20px] p-[2px] gap-[2px]">
        <a
          href={locale === 'en' ? '#' : '/'}
          class:list={['font-mono text-[0.7rem] py-[0.25rem] px-[0.5rem] rounded-[16px] no-underline transition-all duration-150', locale === 'en' ? 'bg-vigie-400/15 text-vigie-400' : 'text-cream-200/50 hover:text-cream-200']}
        >EN</a>
        <a
          href={locale === 'fr' ? '#' : '/fr/'}
          class:list={['font-mono text-[0.7rem] py-[0.25rem] px-[0.5rem] rounded-[16px] no-underline transition-all duration-150', locale === 'fr' ? 'bg-vigie-400/15 text-vigie-400' : 'text-cream-200/50 hover:text-cream-200']}
        >FR</a>
      </div>
      <a
        href="https://github.com/get-tmonier/core"
        class="font-mono text-[0.75rem] bg-vigie-400/10 text-vigie-400 rounded-[6px] py-[0.35rem] px-3 no-underline shadow-[inset_0_0_0_1px_rgba(38,192,154,0.2)] hover:shadow-[inset_0_0_0_1px_rgba(38,192,154,0.4)] hover:bg-vigie-400/15 transition-all duration-150 max-md:hidden"
      >
        {nav.github}
      </a>
    </nav>
  </div>
</header>
<!-- Spacer for fixed header -->
<div class="h-[52px]"></div>
