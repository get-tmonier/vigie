---
import WheelMark from './WheelMark.astro';

interface Props {
  currentPage?: string;
}

const { currentPage = 'home' } = Astro.props;
const isHome = currentPage === 'home';
const isAction = currentPage === 'see-in-action';
const isFaq = currentPage === 'faq';
---

<nav
  class="fixed top-0 left-0 right-0 z-50"
  style="background: rgba(11, 26, 46, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(196, 154, 43, 0.1);"
>
  <div class="flex items-center justify-between px-6 py-4 md:px-10">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <WheelMark size={24} />
      <span
        style="font-family: 'Vollkorn SC', serif; font-weight: 700; font-size: 1.15rem; color: #C49A2B; letter-spacing: 0.03em;"
      >
        Tmonier
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      <a
        href={isHome ? '#how-it-works' : '/#how-it-works'}
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #8B9CAF; text-decoration: none; transition: color 0.2s;"
        onmouseover="this.style.color='#C49A2B'"
        onmouseout="this.style.color='#8B9CAF'"
      >
        How it works
      </a>
      <a
        href={isHome ? '#pricing' : '/#pricing'}
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #8B9CAF; text-decoration: none; transition: color 0.2s;"
        onmouseover="this.style.color='#C49A2B'"
        onmouseout="this.style.color='#8B9CAF'"
      >
        Pricing
      </a>
      <a
        href="/faq"
        style={`font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: ${isFaq ? '#C49A2B' : '#8B9CAF'}; text-decoration: none; transition: color 0.2s;`}
        onmouseover="this.style.color='#C49A2B'"
        onmouseout={`this.style.color='${isFaq ? '#C49A2B' : '#8B9CAF'}'`}
      >
        FAQ
      </a>
      {isAction ? (
        <span
          style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.8rem; color: rgba(196, 154, 43, 0.4); border: 2px solid rgba(196, 154, 43, 0.2); padding: 0.5rem 1.1rem; border-radius: 4px; cursor: default;"
        >
          See it in action
        </span>
      ) : (
        <a
          href="/see-in-action"
          style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.8rem; color: #C49A2B; border: 2px solid rgba(196, 154, 43, 0.5); padding: 0.5rem 1.1rem; border-radius: 4px; text-decoration: none; transition: background 0.2s, border-color 0.2s;"
          onmouseover="this.style.background='rgba(196,154,43,0.1)';this.style.borderColor='#C49A2B'"
          onmouseout="this.style.background='transparent';this.style.borderColor='rgba(196,154,43,0.5)'"
        >
          See it in action
        </a>
      )}
      <a
        href={isHome ? '#waitlist' : '/#waitlist'}
        style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.8rem; background: #C49A2B; color: #0B1A2E; padding: 0.5rem 1.1rem; border-radius: 4px; text-decoration: none; transition: background 0.2s;"
        onmouseover="this.style.background='#D4AA3C'"
        onmouseout="this.style.background='#C49A2B'"
      >
        Claim your spot
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="hamburger-btn"
      class="lg:hidden"
      aria-label="Menu"
      aria-expanded="false"
      style="background: none; border: none; cursor: pointer; padding: 8px;"
    >
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden"
    style="overflow: hidden; max-height: 0; transition: max-height 0.3s ease-in-out; border-top: 1px solid rgba(196, 154, 43, 0);"
  >
    <div style="padding: 0.5rem 1.5rem 1.5rem;">
      <a
        href={isHome ? '#how-it-works' : '/#how-it-works'}
        class="mobile-nav-link"
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #8B9CAF; text-decoration: none; display: block; padding: 0.75rem 0; transition: color 0.2s;"
      >
        How it works
      </a>
      <a
        href={isHome ? '#pricing' : '/#pricing'}
        class="mobile-nav-link"
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #8B9CAF; text-decoration: none; display: block; padding: 0.75rem 0; transition: color 0.2s;"
      >
        Pricing
      </a>
      <a
        href="/faq"
        class="mobile-nav-link"
        style={`font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: ${isFaq ? '#C49A2B' : '#8B9CAF'}; text-decoration: none; display: block; padding: 0.75rem 0; transition: color 0.2s;`}
      >
        FAQ
      </a>
      {isAction ? (
        <span
          class="mobile-nav-link"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: rgba(196, 154, 43, 0.4); display: block; padding: 0.75rem 0; cursor: default;"
        >
          See it in action
        </span>
      ) : (
        <a
          href="/see-in-action"
          class="mobile-nav-link"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #8B9CAF; text-decoration: none; display: block; padding: 0.75rem 0; transition: color 0.2s;"
        >
          See it in action
        </a>
      )}
      <div style="border-top: 1px solid rgba(196, 154, 43, 0.15); margin-top: 0.5rem; padding-top: 0.75rem;">
        <a
          href={isHome ? '#waitlist' : '/#waitlist'}
          class="mobile-nav-link"
          style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.85rem; background: #C49A2B; color: #0B1A2E; padding: 0.65rem 1.1rem; border-radius: 4px; text-decoration: none; display: block; text-align: center; transition: background 0.2s;"
        >
          Claim your spot
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer so content isn't hidden under the fixed nav -->
<div style="height: 64px;"></div>

<style>
  #hamburger-btn {
    flex-direction: column;
    gap: 5px;
  }

  @media (max-width: 1023px) {
    #hamburger-btn {
      display: flex;
    }
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: #C49A2B;
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  #hamburger-btn.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #hamburger-btn.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  #hamburger-btn.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburgerBtn && mobileMenu) {
    hamburgerBtn.addEventListener('click', () => {
      const isOpen = hamburgerBtn.classList.toggle('is-open');
      hamburgerBtn.setAttribute('aria-expanded', String(isOpen));
      mobileMenu.style.maxHeight = isOpen ? `${mobileMenu.scrollHeight}px` : '0';
      mobileMenu.style.borderTopColor = isOpen ? 'rgba(196, 154, 43, 0.15)' : 'rgba(196, 154, 43, 0)';
    });

    // Close menu when a link is clicked
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        hamburgerBtn.classList.remove('is-open');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.style.maxHeight = '0';
        mobileMenu.style.borderTopColor = 'rgba(196, 154, 43, 0)';
      });
    });

    // Close menu on resize to desktop
    const mediaQuery = window.matchMedia('(min-width: 1024px)');
    mediaQuery.addEventListener('change', (e) => {
      if (e.matches) {
        hamburgerBtn.classList.remove('is-open');
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.style.maxHeight = '0';
        mobileMenu.style.borderTopColor = 'rgba(196, 154, 43, 0)';
      }
    });
  }
</script>
