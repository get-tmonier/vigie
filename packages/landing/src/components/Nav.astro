---
import WheelMark from '#components/WheelMark.astro';
import type { SiteContent } from '../i18n/types';

interface Props {
  locale: string;
  content: SiteContent;
  currentPage?: string;
}

const { locale, content, currentPage = 'home' } = Astro.props;
const { nav } = content;
const isHome = currentPage === 'home';
const isContact = currentPage === 'contact';
const altLocale = locale === 'fr' ? 'en' : 'fr';
const altHref = locale === 'fr' ? '/' : '/fr/';
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-navy-deep/92 backdrop-blur-[12px] border-b border-gold/10"
>
  <div class="flex items-center justify-between px-6 py-4 md:px-10">
    <!-- Logo -->
    <a href={locale === 'fr' ? '/fr/' : '/'} class="flex items-center gap-3 no-underline">
      <WheelMark size={24} />
      <span class="font-vollkorn-sc text-gold font-bold text-[1.15rem] tracking-[0.03em]">
        Tmonier
      </span>
    </a>

    <!-- Desktop nav links -->
    <div class="hidden lg:flex items-center gap-8">
      <a
        href={isHome ? '#approach' : (locale === 'fr' ? '/fr/#approach' : '/#approach')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.approach}
      </a>
      <a
        href={isHome ? '#stack' : (locale === 'fr' ? '/fr/#stack' : '/#stack')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.stack}
      </a>
      <a
        href={isHome ? '#experience' : (locale === 'fr' ? '/fr/#experience' : '/#experience')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.experience}
      </a>
      <a
        href={isHome ? '#projects' : (locale === 'fr' ? '/fr/#projects' : '/#projects')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.projects}
      </a>
      <a
        href={isHome ? '#project' : (locale === 'fr' ? '/fr/#project' : '/#project')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.vigie}
      </a>
      <a
        href={isHome ? '#about' : (locale === 'fr' ? '/fr/#about' : '/#about')}
        class="font-mono text-slate text-[0.8rem] no-underline transition-colors duration-200 hover:text-gold"
      >
        {nav.about}
      </a>
      <a
        href={isContact ? '#main' : (locale === 'fr' ? '/fr/contact' : '/contact')}
        class:list={['font-mono text-[0.8rem] no-underline transition-colors duration-200', isContact ? 'text-gold' : 'text-slate hover:text-gold']}
      >
        {nav.contact}
      </a>

      <!-- Language toggle -->
      <div class="flex items-center bg-navy-mid/50 rounded-[20px] p-[3px] gap-[2px]">
        <a
          href={locale === 'en' ? '#' : '/'}
          class:list={[
            'font-mono text-[0.7rem] font-semibold py-1 px-[0.65rem] rounded-[16px] no-underline transition-all duration-150',
            locale === 'en' ? 'bg-gold text-navy-deep' : 'bg-transparent text-slate hover:text-cream',
          ]}
          aria-current={locale === 'en' ? 'true' : undefined}
        >EN</a>
        <a
          href={locale === 'fr' ? '#' : '/fr/'}
          class:list={[
            'font-mono text-[0.7rem] font-semibold py-1 px-[0.65rem] rounded-[16px] no-underline transition-all duration-150',
            locale === 'fr' ? 'bg-gold text-navy-deep' : 'bg-transparent text-slate hover:text-cream',
          ]}
          aria-current={locale === 'fr' ? 'true' : undefined}
        >FR</a>
      </div>

      <a
        href={locale === 'fr' ? '/fr/contact' : '/contact'}
        class="font-mono bg-gold text-navy-deep font-semibold text-[0.8rem] py-2 px-[1.1rem] rounded-[4px] no-underline transition-colors duration-200 hover:bg-gold-light"
      >
        {content.hero.ctaPrimary}
      </a>
    </div>

    <!-- Mobile language toggle + hamburger -->
    <div class="lg:hidden flex items-center gap-3">
      <div class="flex items-center bg-navy-mid/50 rounded-[16px] p-[2px] gap-[2px]">
        <a
          href={locale === 'en' ? '#' : '/'}
          class:list={[
            'font-mono text-[0.6rem] font-semibold py-[3px] px-[0.5rem] rounded-[12px] no-underline transition-all duration-150',
            locale === 'en' ? 'bg-gold text-navy-deep' : 'bg-transparent text-slate',
          ]}
        >EN</a>
        <a
          href={locale === 'fr' ? '#' : '/fr/'}
          class:list={[
            'font-mono text-[0.6rem] font-semibold py-[3px] px-[0.5rem] rounded-[12px] no-underline transition-all duration-150',
            locale === 'fr' ? 'bg-gold text-navy-deep' : 'bg-transparent text-slate',
          ]}
        >FR</a>
      </div>
    <button
      id="hamburger-btn"
      class="bg-transparent border-none cursor-pointer p-2 flex flex-col gap-[5px]"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="hamburger-bar block w-[22px] h-0.5 bg-gold rounded-[1px] transition-[transform,opacity] duration-300 ease-in-out"></span>
      <span class="hamburger-bar block w-[22px] h-0.5 bg-gold rounded-[1px] transition-[transform,opacity] duration-300 ease-in-out"></span>
      <span class="hamburger-bar block w-[22px] h-0.5 bg-gold rounded-[1px] transition-[transform,opacity] duration-300 ease-in-out"></span>
    </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out border-t border-transparent"
  >
    <div class="pt-2 px-6 pb-6">
      <a
        href={isHome ? '#approach' : (locale === 'fr' ? '/fr/#approach' : '/#approach')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.approach}
      </a>
      <a
        href={isHome ? '#stack' : (locale === 'fr' ? '/fr/#stack' : '/#stack')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.stack}
      </a>
      <a
        href={isHome ? '#experience' : (locale === 'fr' ? '/fr/#experience' : '/#experience')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.experience}
      </a>
      <a
        href={isHome ? '#projects' : (locale === 'fr' ? '/fr/#projects' : '/#projects')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.projects}
      </a>
      <a
        href={isHome ? '#project' : (locale === 'fr' ? '/fr/#project' : '/#project')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.vigie}
      </a>
      <a
        href={isHome ? '#about' : (locale === 'fr' ? '/fr/#about' : '/#about')}
        class="mobile-nav-link font-mono text-slate text-[0.85rem] no-underline block py-3 transition-colors duration-200 hover:text-gold"
      >
        {nav.about}
      </a>
      <a
        href={isContact ? '#main' : (locale === 'fr' ? '/fr/contact' : '/contact')}
        class:list={['mobile-nav-link font-mono text-[0.85rem] no-underline block py-3 transition-colors duration-200', isContact ? 'text-gold' : 'text-slate hover:text-gold']}
      >
        {nav.contact}
      </a>



      <div class="border-t border-gold/15 mt-2 pt-3">
        <a
          href={locale === 'fr' ? '/fr/contact' : '/contact'}
          class="mobile-nav-link font-mono bg-gold text-navy-deep font-semibold text-[0.85rem] py-[0.65rem] px-[1.1rem] rounded-[4px] no-underline block text-center transition-colors duration-200 hover:bg-gold-light"
        >
          {content.hero.ctaPrimary}
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Spacer so content isn't hidden under the fixed nav -->
<div class="h-16"></div>

<script>
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburgerBtn && mobileMenu) {
    const bars = hamburgerBtn.querySelectorAll<HTMLElement>('.hamburger-bar');

    function setOpen(open: boolean) {
      hamburgerBtn!.setAttribute('aria-expanded', String(open));
      mobileMenu!.style.maxHeight = open ? `${mobileMenu!.scrollHeight}px` : '0';
      mobileMenu!.style.borderTopColor = open ? 'color-mix(in srgb, var(--gold) 15%, transparent)' : '';
      if (bars[0]) bars[0].style.transform = open ? 'translateY(7px) rotate(45deg)' : '';
      if (bars[1]) bars[1].style.opacity = open ? '0' : '';
      if (bars[2]) bars[2].style.transform = open ? 'translateY(-7px) rotate(-45deg)' : '';
    }

    let isOpen = false;
    hamburgerBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      setOpen(isOpen);
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        isOpen = false;
        setOpen(false);
      });
    });

    const mediaQuery = window.matchMedia('(min-width: 1024px)');
    mediaQuery.addEventListener('change', (e) => {
      if (e.matches) {
        isOpen = false;
        setOpen(false);
      }
    });
  }
</script>
