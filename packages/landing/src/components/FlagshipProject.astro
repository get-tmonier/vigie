---
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { flagship } = content;
---

<section id="project" class="bg-navy-deep py-16 px-10 min-h-[1200px] max-md:py-10 max-md:px-5 max-md:min-h-0">
  <div class="max-w-[1000px] mx-auto">
    <p class="reveal-up font-mono text-gold text-[0.75rem] tracking-[0.15em] uppercase m-0 mb-3 text-center" style="--delay: 0ms">
      {flagship.label}
    </p>
    <h2 class="reveal-up font-vollkorn-sc text-gold font-black text-[clamp(1.6rem,3vw,2.2rem)] m-0 mb-3 leading-[1.2] text-center" style="--delay: 80ms">
      {flagship.title}
    </h2>
    <p class="reveal-up font-source-serif text-slate text-[0.95rem] m-0 mb-8 leading-[1.7] text-center max-w-[600px] mx-auto" style="--delay: 160ms">
      {flagship.description}
    </p>

    <!-- Full DashboardDemo animation -->
    <div id="flagship-demo" class="overflow-hidden">
      <!-- 1. Local daemon terminal -->
      <div
        class="fp-terminal font-mono opacity-0 translate-y-6 max-w-[520px] mx-auto mb-6 rounded-[10px] overflow-hidden border border-slate/15 shadow-[0_16px_48px_rgba(0,0,0,0.3)] max-md:max-w-full"
      >
        <div class="bg-navy-mid/50 py-[0.55rem] px-[0.85rem] flex gap-[0.45rem] items-center border-b border-slate/10">
          <span class="size-[10px] rounded-full inline-block bg-signal-red"></span>
          <span class="size-[10px] rounded-full inline-block bg-signal-amber"></span>
          <span class="size-[10px] rounded-full inline-block bg-signal-green"></span>
          <span class="text-[0.6rem] text-slate/40 ml-[0.4rem]">zsh — ~/projects/my-app</span>
        </div>
        <div class="bg-navy-deep/60 py-4 px-5 text-[0.68rem] leading-[2]">
          <div><span class="text-gold">$</span><span class="text-gold-pale"> vigie start</span></div>
          <div class="text-slate"><span class="text-signal-green">&#10003;</span> daemon running on localhost:4800</div>
          <div class="text-slate/50">watching claude-code · all events forwarded to dashboard</div>
          <div class="text-slate/35 text-[0.58rem] mt-[0.15rem]">local-first &mdash; your data never leaves your machine</div>
          <div class="mt-[0.35rem]"><span class="text-gold">$</span><span class="inline-block w-[7px] h-[1em] bg-gold ml-1 align-text-bottom animate-[blink_1.2s_step-end_infinite]"></span></div>
        </div>
      </div>

      <!-- 2. WebSocket connector -->
      <div class="fp-ws-connector font-mono grid grid-rows-[0fr] opacity-0 [transition:grid-template-rows_1.6s_cubic-bezier(0.22,1,0.36,1),opacity_1s_ease] max-md:grid-rows-[1fr]">
        <div class="flex flex-col items-center overflow-hidden min-h-0">
          <div class="fp-ws-top w-[2px] h-[28px] scale-y-0 origin-top transition-[scale] duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)]" style="background: repeating-linear-gradient(to bottom, color-mix(in srgb, var(--signal-green) 30%, transparent) 0px, color-mix(in srgb, var(--signal-green) 30%, transparent) 4px, transparent 4px, transparent 8px)"></div>
          <div class="fp-ws-badge flex items-center gap-[0.4rem] bg-signal-green/7 border border-signal-green/25 rounded-[20px] py-1 px-3 my-1 opacity-0 transition-opacity duration-[400ms]">
            <span class="size-[6px] rounded-full inline-block shrink-0 bg-signal-green animate-[pulse-soft_2s_ease-in-out_infinite]"></span>
            <span class="text-[0.52rem] text-signal-green tracking-[0.04em]">ws://localhost:4800</span>
          </div>
          <div class="fp-ws-bottom w-[2px] h-[48px] scale-y-0 origin-top transition-[scale] duration-[600ms] ease-[cubic-bezier(0.16,1,0.3,1)]" style="background: repeating-linear-gradient(to bottom, color-mix(in srgb, var(--signal-green) 30%, transparent) 0px, color-mix(in srgb, var(--signal-green) 30%, transparent) 4px, transparent 4px, transparent 8px)"></div>
        </div>
      </div>

      <!-- 3. Browser dashboard mockup -->
      <div class="fp-browser grid grid-rows-[0fr] opacity-0 [transition:grid-template-rows_1.8s_cubic-bezier(0.22,1,0.36,1),opacity_1.2s_ease] max-md:grid-rows-[1fr]">
        <div class="flex flex-col items-center overflow-hidden min-h-0">
          <div class="font-mono max-w-[920px] w-full rounded-xl overflow-hidden border border-gold/20 shadow-[0_32px_80px_rgba(0,0,0,0.5)]">
            <!-- Browser chrome -->
            <div class="bg-navy-mid/70 py-[0.65rem] px-4 flex items-center gap-2 border-b border-gold/10">
              <span class="size-3 rounded-full inline-block shrink-0 bg-signal-red"></span>
              <span class="size-3 rounded-full inline-block shrink-0 bg-signal-amber"></span>
              <span class="size-3 rounded-full inline-block shrink-0 bg-signal-green"></span>
              <div class="flex-1 mx-3 bg-navy-deep/70 border border-slate/15 rounded-md py-1 px-3 flex items-center gap-[0.4rem] max-w-[320px] ml-auto mr-auto">
                <svg width="10" height="12" viewBox="0 0 10 12" fill="none" class="shrink-0 opacity-50 text-slate"><path d="M5 0C3.067 0 1.5 1.567 1.5 3.5V5H1C0.448 5 0 5.448 0 6v5c0 .552.448 1 1 1h8c.552 0 1-.448 1-1V6c0-.552-.448-1-1-1H8.5V3.5C8.5 1.567 6.933 0 5 0zm2.5 5h-5V3.5C2.5 2.12 3.62 1 5 1s2.5 1.12 2.5 2.5V5z" fill="currentColor"/></svg>
                <span class="text-[0.65rem] text-slate/60">app.vigie.tmonier.com</span>
              </div>
            </div>
            <!-- Browser body -->
            <div class="flex bg-navy-deep/50 max-md:flex-col">
              <!-- Sidebar -->
              <div class="w-[180px] shrink-0 bg-navy-deep/60 border-r border-gold/10 py-5 max-md:hidden">
                <div class="px-4 pb-5 border-b border-slate/10 mb-4">
                  <div class="flex items-center gap-2">
                    <span class="text-[0.78rem] text-gold font-semibold">vigie</span>
                  </div>
                </div>
                <nav class="px-3 flex flex-col gap-[0.15rem]">
                  <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md bg-gold/8 border border-gold/15">
                    <span class="size-[6px] rounded-full inline-block shrink-0 bg-signal-green"></span>
                    <span class="text-[0.7rem] text-cream">Agents</span>
                  </div>
                  <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md">
                    <span class="size-[6px] rounded-full inline-block shrink-0"></span>
                    <span class="text-[0.7rem] text-slate">Runs</span>
                  </div>
                  <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md">
                    <span class="size-[6px] rounded-full inline-block shrink-0"></span>
                    <span class="text-[0.7rem] text-slate">Settings</span>
                  </div>
                </nav>
              </div>
              <!-- Main area -->
              <div class="flex-1 p-5 bg-navy-deep/40 min-w-0 relative max-md:p-3">
                <div class="flex items-center justify-between mb-4 gap-2">
                  <span class="text-[0.7rem] text-cream font-semibold">Rate-limit /api/users</span>
                  <div class="flex items-center gap-[0.6rem]">
                    <span class="text-[0.65rem] bg-signal-green/12 text-signal-green border border-signal-green/30 rounded-[10px] py-[0.1rem] px-[0.55rem]">1 agent active</span>
                    <span class="fp-cost text-[0.65rem] text-slate">$0.00</span>
                  </div>
                </div>
                <!-- Agent card -->
                <div class="fp-agent opacity-0 bg-navy-mid/50 rounded-lg p-3 mb-4 border border-signal-green/30 transition-[opacity,transform] duration-300 ease-out max-md:p-[0.6rem]">
                  <div class="flex items-center justify-between mb-[0.4rem] max-md:flex-col max-md:items-start max-md:gap-1">
                    <div class="flex items-center gap-[0.35rem]">
                      <span class="size-[6px] rounded-full inline-block bg-signal-green"></span>
                      <span class="text-[0.7rem] text-gold font-semibold">Claude Code</span>
                      <span class="text-[0.5rem] bg-slate/10 border border-slate/20 rounded-[4px] py-[0.05rem] px-[0.35rem] text-slate">opus</span>
                    </div>
                    <span class="text-[0.6rem] text-slate/60 max-md:text-[0.52rem]">src/middleware/rate-limit.ts</span>
                  </div>
                  <div class="flex items-center gap-2 mt-[0.55rem]">
                    <span class="text-[0.5rem] text-slate/50 shrink-0">context</span>
                    <div class="flex-1 h-[3px] bg-slate/15 rounded-sm overflow-hidden">
                      <div class="fp-ctx-bar h-full w-0 rounded-[2px] bg-signal-green [transition:width_1.5s_ease-out,background_0.5s_ease]"></div>
                    </div>
                    <span class="fp-ctx-pct text-[0.5rem] text-slate/50 shrink-0 min-w-[2.2em] text-right">0%</span>
                  </div>
                </div>
                <!-- Activity log -->
                <div class="bg-navy-deep/50 border border-slate/10 rounded-md py-[0.6rem] px-3 mb-3">
                  <div class="text-[0.55rem] tracking-[0.08em] uppercase text-slate/40 mb-2">Activity</div>
                  <div class="fp-log flex flex-col gap-1 h-[130px] max-md:h-[160px] overflow-y-hidden"></div>
                </div>
                <!-- Action panel -->
                <div class="fp-action-wrap grid grid-rows-[0fr] [transition:grid-template-rows_0.6s_cubic-bezier(0.22,1,0.36,1)]">
                  <div class="fp-action opacity-0 translate-y-2 overflow-hidden min-h-0 bg-navy-mid/40 border border-gold/30 rounded-lg p-3 max-md:p-2">
                    <div class="flex items-center justify-between mb-[0.6rem]">
                      <div class="flex items-center gap-[0.4rem]">
                        <span class="text-[0.6rem] text-signal-amber font-bold">&#9888;</span>
                        <span class="text-[0.62rem] text-cream font-semibold">Agent paused &mdash; loop detected</span>
                      </div>
                      <span class="text-[0.55rem] text-signal-orange">$4.20 spent</span>
                    </div>
                    <div class="bg-navy-deep/60 border border-slate/15 rounded-md py-[0.55rem] px-[0.65rem] mb-[0.6rem]">
                      <div class="text-[0.5rem] tracking-[0.08em] uppercase text-slate/40 mb-[0.3rem]">Suggested prompt</div>
                      <p class="fp-prompt text-[0.6rem] text-cream m-0 leading-[1.6] italic min-h-[1.6em] max-md:min-h-[4.8em]"></p>
                    </div>
                    <div class="flex gap-[0.35rem] justify-end flex-wrap">
                      <div class="fp-btn-rollback opacity-0 flex items-center gap-[0.3rem] text-[0.58rem] bg-gold/12 border border-gold/35 rounded-[5px] py-[0.35rem] px-[0.6rem] text-gold font-semibold cursor-default">
                        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="shrink-0"><path d="M2 8a6 6 0 1 1 1.76 4.24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M2 4v4h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Rollback #3
                      </div>
                      <div class="fp-btn-resume opacity-0 flex items-center gap-[0.3rem] text-[0.58rem] bg-signal-green/10 border border-signal-green/30 rounded-[5px] py-[0.35rem] px-[0.6rem] text-signal-green font-semibold cursor-default">
                        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="shrink-0"><path d="M2 8h12M10 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Resume
                      </div>
                      <div class="fp-btn-stop opacity-0 text-[0.58rem] bg-signal-red/8 border border-signal-red/25 rounded-[5px] py-[0.35rem] px-[0.6rem] text-signal-red/70 cursor-default">Stop agent</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-8">
      <a
        href="https://vigie.tmonier.com"
        class="reveal-up font-mono text-gold font-semibold text-[0.85rem] no-underline border border-gold/40 rounded-[4px] py-[0.7rem] px-[1.4rem] inline-block transition-all duration-200 hover:bg-gold/10 hover:border-gold/60"
        style="--delay: 240ms"
      >
        {flagship.cta}
      </a>
    </div>
  </div>
</section>

<script>
  const demo = document.getElementById('flagship-demo');
  if (demo) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Phase 1: Terminal fades in
            const terminal = demo.querySelector<HTMLElement>('.fp-terminal');
            if (terminal) terminal.classList.add('animate-[fade-up_0.5s_cubic-bezier(0.16,1,0.3,1)_forwards]');

            // Phase 2: WS connector + browser grow
            const ws = demo.querySelector<HTMLElement>('.fp-ws-connector');
            const browser = demo.querySelector<HTMLElement>('.fp-browser');
            if (ws) { setTimeout(() => { ws.style.gridTemplateRows = '1fr'; }, 800); setTimeout(() => { ws.style.opacity = '1'; }, 1000); }
            if (browser) { setTimeout(() => { browser.style.gridTemplateRows = '1fr'; }, 800); setTimeout(() => { browser.style.opacity = '1'; }, 1000); }

            // Phase 3: WS lines draw
            const wsTop = demo.querySelector<HTMLElement>('.fp-ws-top');
            const wsBadge = demo.querySelector<HTMLElement>('.fp-ws-badge');
            const wsBottom = demo.querySelector<HTMLElement>('.fp-ws-bottom');
            if (wsTop) setTimeout(() => { wsTop.classList.remove('scale-y-0'); wsTop.classList.add('animate-[scroll-stripe_0.6s_linear_infinite]'); }, 2000);
            if (wsBadge) setTimeout(() => { wsBadge.style.opacity = '1'; }, 2300);
            if (wsBottom) setTimeout(() => { wsBottom.classList.remove('scale-y-0'); wsBottom.classList.add('animate-[scroll-stripe_0.6s_linear_infinite]'); }, 2400);

            // Phase 4: Dashboard internals
            const t0 = 2800;
            const logEl = demo.querySelector<HTMLElement>('.fp-log');
            if (!logEl) return;

            const agent = demo.querySelector<HTMLElement>('.fp-agent');
            if (agent) setTimeout(() => { agent.style.opacity = '1'; }, t0);

            const logs = [
              { time: '14:32:01', html: '<span class="text-slate">claude-code</span> · reading <span class="text-signal-green">src/api/users.ts</span>', delay: 200 },
              { time: '14:33:12', html: '<span class="text-slate">claude-code</span> · created <span class="text-signal-green">src/middleware/rate-limit.ts</span>', delay: 350 },
              { time: '14:34:30', html: '<span class="text-slate">claude-code</span> · running <span class="text-cream">npm test</span> — <span class="text-signal-red">3 failed</span>', delay: 550 },
              { time: '14:35:15', html: '<span class="text-slate">claude-code</span> · editing <span class="text-cream">src/middleware/rate-limit.ts</span>', delay: 250 },
              { time: '14:36:48', html: '<span class="text-slate">claude-code</span> · running <span class="text-cream">npm test</span> — <span class="text-signal-red">3 failed</span>', delay: 600 },
              { time: '14:37:02', html: '<span class="text-signal-amber">\u26a0 scope drift · <span class="text-signal-amber/70">agent modified package.json — outside declared scope</span></span>', delay: 400 },
              { time: '14:37:45', html: '<span class="text-signal-orange">\u26a0 context 65% · <span class="text-signal-orange/70">agent may lose early instructions</span></span>', delay: 300 },
              { time: '14:38:01', html: '<span class="text-slate">$ cost hint · <span class="text-slate/70">this task could run on <span class="text-cream">sonnet</span> — ~3x cheaper</span></span>', delay: 200 },
              { time: '14:38:03', html: '<span class="text-signal-amber">\u26a0 loop detected · <span class="text-signal-amber/70">edit \u2192 test \u2192 fail \u2192 edit — 4 cycles in 6 min</span></span>', delay: 500 },
            ];

            let elapsed = t0 + 300;
            for (const log of logs) {
              elapsed += log.delay;
              const t = elapsed;
              setTimeout(() => {
                const div = document.createElement('div');
                div.className = 'font-mono text-[0.62rem] leading-[1.8] flex gap-2 items-baseline max-md:text-[0.55rem]';
                div.style.color = 'color-mix(in srgb, var(--slate) 55%, transparent)';
                div.innerHTML = `<span class="shrink-0" style="color: color-mix(in srgb, var(--slate) 35%, transparent)">${log.time}</span><span>${log.html}</span>`;
                logEl.appendChild(div);
                logEl.scrollTop = logEl.scrollHeight;
              }, t);
            }
            const loopT = elapsed;

            // Agent card turns amber
            setTimeout(() => { if (agent) { agent.style.transition = 'border-color 0.4s ease'; agent.style.borderColor = 'var(--signal-amber)'; } }, loopT);

            // Action panel
            const actionWrap = demo.querySelector<HTMLElement>('.fp-action-wrap');
            const action = demo.querySelector<HTMLElement>('.fp-action');
            if (actionWrap) setTimeout(() => { actionWrap.style.gridTemplateRows = '1fr'; }, loopT + 300);
            if (action) setTimeout(() => { action.style.transition = 'opacity 0.3s ease-out, transform 0.3s ease-out'; action.style.opacity = '1'; action.style.transform = 'translateY(0)'; action.style.animation = 'pulse-amber 2.5s ease-in-out 0.3s infinite'; }, loopT + 500);

            // Suggested prompt streaming
            const promptEl = demo.querySelector<HTMLElement>('.fp-prompt');
            if (promptEl) {
              const text = '\u201cTests expect a Redis mock \u2014 use ioredis-mock in the test setup instead of connecting to a real instance.\u201d';
              const words = text.split(' ');
              const tokens: string[] = [];
              for (let i = 0; i < words.length; i += 2) tokens.push(words.slice(i, i + 2).join(' '));
              let idx = 0;
              const stream = () => {
                if (idx >= tokens.length) { const c = promptEl.querySelector('.stream-cursor'); if (c) c.remove(); return; }
                promptEl.textContent = (promptEl.textContent || '') + (idx > 0 ? ' ' : '') + tokens[idx];
                let cursor = promptEl.querySelector('.stream-cursor') as HTMLElement;
                if (!cursor) { cursor = document.createElement('span'); cursor.className = 'stream-cursor inline-block w-[5px] h-[0.85em] bg-cream ml-[2px] align-text-bottom animate-[blink_0.6s_step-end_infinite] opacity-70'; }
                promptEl.appendChild(cursor);
                idx++;
                setTimeout(stream, 80 + Math.random() * 120);
              };
              setTimeout(stream, loopT + 600);
            }

            // Action buttons stagger
            const btns = ['.fp-btn-rollback', '.fp-btn-resume', '.fp-btn-stop'];
            btns.forEach((sel, i) => {
              const btn = demo.querySelector<HTMLElement>(sel);
              if (btn) setTimeout(() => { btn.style.transition = 'opacity 0.15s ease-out'; btn.style.opacity = '1'; }, loopT + 700 + i * 100);
            });

            // Context bar
            const ctxBar = demo.querySelector<HTMLElement>('.fp-ctx-bar');
            const ctxPct = demo.querySelector<HTMLElement>('.fp-ctx-pct');
            if (ctxBar && ctxPct) {
              const steps = [
                { delay: t0 + 550, width: '18', pct: '18%', color: 'var(--signal-green)' },
                { delay: t0 + 1100, width: '31', pct: '31%', color: 'var(--signal-green)' },
                { delay: t0 + 1350, width: '44', pct: '44%', color: 'var(--signal-amber)' },
                { delay: t0 + 1950, width: '57', pct: '57%', color: 'var(--signal-amber)' },
                { delay: loopT, width: '65', pct: '65%', color: 'var(--signal-orange)' },
              ];
              for (const s of steps) setTimeout(() => { ctxBar.style.width = s.width + '%'; ctxBar.style.background = s.color; ctxPct.textContent = s.pct; ctxPct.style.color = s.color; }, s.delay);
            }

            // Cost counter
            const costEl = demo.querySelector<HTMLElement>('.fp-cost');
            if (costEl) {
              const costs = [
                { delay: t0 + 550, value: '$0.40', color: '' },
                { delay: t0 + 1100, value: '$1.12', color: '' },
                { delay: t0 + 1350, value: '$2.30', color: 'var(--signal-amber)' },
                { delay: t0 + 1950, value: '$3.45', color: 'var(--signal-orange)' },
                { delay: loopT, value: '$4.20', color: 'var(--signal-orange)' },
              ];
              for (const c of costs) setTimeout(() => { costEl.textContent = c.value; if (c.color) costEl.style.color = c.color; }, c.delay);
            }

            observer.unobserve(demo);
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(demo);
  }
</script>
