---
import WheelMark from '#components/WheelMark.astro';
---

<section id="waitlist" class="waitlist-section bg-navy-deep" style="padding: 6rem 2.5rem; text-align: center;">
  <div style="max-width: 600px; margin: 0 auto;">
    <div style="display: flex; justify-content: center; margin-bottom: 2.5rem;">
      <WheelMark size={80} />
    </div>

    <h2
      class="font-vollkorn text-slate"
      style="font-weight: 700; font-size: clamp(1.4rem, 3vw, 1.9rem); margin: 0 0 1rem; line-height: 1.35;"
    >
      AI writes the code.
    </h2>

    <p
      class="font-vollkorn-sc text-gold"
      style="font-weight: 700; font-size: clamp(1.3rem, 3vw, 1.8rem); margin: 0 0 1.5rem; line-height: 1.3;"
    >
      You hold the helm.
    </p>

    <p
      class="font-mono text-cream"
      style="font-size: 0.82rem; margin: 0 0 2rem; line-height: 1.6;"
    >
      Early adopters get their <span class="text-gold" style="font-weight: 600;">first month free</span> on the Solo plan.
    </p>

    <div class="newsletter-form-container">
      <form
        class="newsletter-form waitlist-form"
        action="https://app.loops.so/api/newsletter-form/cmm61m1au0ws70i1mpmh6f87r"
        method="POST"
        style="display: flex; gap: 0.75rem; max-width: 480px; margin: 0 auto 1rem;"
      >
        <input
          class="newsletter-form-input font-mono text-cream"
          type="email"
          name="newsletter-form-input"
          placeholder="your@email.com"
          required
          autocomplete="email"
          style="flex: 1; font-size: 0.85rem; background: rgba(29, 53, 87, 0.5); border: 1px solid rgba(196, 154, 43, 0.25); border-radius: 4px; padding: 0.8rem 1rem; outline: none; min-width: 0;"
          onfocus="this.style.borderColor='rgba(196,154,43,0.6)'"
          onblur="this.style.borderColor='rgba(196,154,43,0.25)'"
        />
        <button
          type="submit"
          class="newsletter-form-button font-mono bg-gold text-navy-deep"
          style="font-weight: 600; font-size: 0.85rem; border: none; border-radius: 4px; padding: 0.8rem 1.4rem; cursor: pointer; white-space: nowrap; transition: background 0.2s;"
          onmouseover="this.style.background='#D4AA3C'"
          onmouseout="this.style.background='#C49A2B'"
        >
          Claim your spot
        </button>
        <button
          type="button"
          class="newsletter-loading-button font-mono bg-gold text-navy-deep"
          style="display: none; font-weight: 600; font-size: 0.85rem; border: none; border-radius: 4px; padding: 0.8rem 1.4rem; white-space: nowrap; opacity: 0.7; cursor: not-allowed;"
        >
          Sending…
        </button>
      </form>

      <div class="newsletter-success" style="display: none; justify-content: center; align-items: center; padding: 0.8rem; margin-bottom: 1rem;">
        <p class="font-mono text-gold" style="font-size: 0.82rem; margin: 0;">
          &#10003; You're on the list. We'll be in touch when the beta opens.
        </p>
      </div>

      <div class="newsletter-error" style="display: none; justify-content: center; align-items: center; padding: 0.8rem; margin-bottom: 1rem;">
        <p class="newsletter-error-message font-mono" style="font-size: 0.82rem; color: #c0392b; margin: 0;">
          Oops! Something went wrong, please try again
        </p>
      </div>

      <button
        class="newsletter-back-button font-mono text-slate"
        type="button"
        style="display: none; font-size: 0.75rem; background: transparent; border: none; cursor: pointer; margin: 0.5rem auto;"
        onmouseover="this.style.textDecoration='underline'"
        onmouseout="this.style.textDecoration='none'"
      >
        &larr; Back
      </button>
    </div>

    <p
      class="font-mono"
      style="font-size: 0.72rem; color: rgba(139,156,175,0.6); margin: 0;"
    >
      Limited spots — no spam, just your invite when the beta opens.
    </p>
  </div>
</section>

<script>
  function submitHandler(event: SubmitEvent) {
    event.preventDefault();
    const container = (event.target as HTMLElement).parentNode as HTMLElement;
    const form = container.querySelector<HTMLFormElement>('.newsletter-form')!;
    const formInput = container.querySelector<HTMLInputElement>('.newsletter-form-input')!;
    const success = container.querySelector<HTMLElement>('.newsletter-success')!;
    const errorContainer = container.querySelector<HTMLElement>('.newsletter-error')!;
    const errorMessage = container.querySelector<HTMLElement>('.newsletter-error-message')!;
    const backButton = container.querySelector<HTMLButtonElement>('.newsletter-back-button')!;
    const submitButton = container.querySelector<HTMLButtonElement>('.newsletter-form-button')!;
    const loadingButton = container.querySelector<HTMLButtonElement>('.newsletter-loading-button')!;

    const rateLimit = () => {
      errorContainer.style.display = 'flex';
      errorMessage.innerText = 'Too many signups, please try again in a little while';
      submitButton.style.display = 'none';
      formInput.style.display = 'none';
      backButton.style.display = 'block';
    };

    const time = new Date();
    const timestamp = time.valueOf();
    const previousTimestamp = localStorage.getItem('loops-form-timestamp');
    if (previousTimestamp && Number(previousTimestamp) + 60000 > timestamp) {
      rateLimit();
      return;
    }
    localStorage.setItem('loops-form-timestamp', String(timestamp));

    submitButton.style.display = 'none';
    loadingButton.style.display = 'flex';

    const formBody = 'userGroup=&mailingLists=&email=' + encodeURIComponent(formInput.value);

    fetch((event.target as HTMLFormElement).action, {
      method: 'POST',
      body: formBody,
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    })
      .then((res) => Promise.all([res.ok, res.json()]))
      .then(([ok, data]) => {
        if (ok) {
          success.style.display = 'flex';
          form.reset();
        } else {
          errorContainer.style.display = 'flex';
          errorMessage.innerText = data.message ?? 'Something went wrong';
        }
      })
      .catch((error: Error) => {
        if (error.message === 'Failed to fetch') { rateLimit(); return; }
        errorContainer.style.display = 'flex';
        if (error.message) errorMessage.innerText = error.message;
        localStorage.setItem('loops-form-timestamp', '');
      })
      .finally(() => {
        formInput.style.display = 'none';
        loadingButton.style.display = 'none';
        backButton.style.display = 'block';
      });
  }

  function resetFormHandler(event: MouseEvent) {
    const container = (event.target as HTMLElement).parentNode as HTMLElement;
    const formInput = container.querySelector<HTMLInputElement>('.newsletter-form-input')!;
    const success = container.querySelector<HTMLElement>('.newsletter-success')!;
    const errorContainer = container.querySelector<HTMLElement>('.newsletter-error')!;
    const errorMessage = container.querySelector<HTMLElement>('.newsletter-error-message')!;
    const backButton = container.querySelector<HTMLButtonElement>('.newsletter-back-button')!;
    const submitButton = container.querySelector<HTMLButtonElement>('.newsletter-form-button')!;

    success.style.display = 'none';
    errorContainer.style.display = 'none';
    errorMessage.innerText = 'Oops! Something went wrong, please try again';
    backButton.style.display = 'none';
    formInput.style.display = 'flex';
    submitButton.style.display = 'flex';
  }

  const formContainers = document.getElementsByClassName('newsletter-form-container');
  for (let i = 0; i < formContainers.length; i++) {
    const container = formContainers[i];
    if (container.classList.contains('newsletter-handlers-added')) continue;
    container.querySelector('.newsletter-form')!.addEventListener('submit', submitHandler as EventListener);
    container.querySelector('.newsletter-back-button')!.addEventListener('click', resetFormHandler as EventListener);
    container.classList.add('newsletter-handlers-added');
  }
</script>

<style>
  @media (max-width: 540px) {
    .waitlist-form {
      flex-direction: column !important;
    }
  }

  .waitlist-section {
    min-height: calc(100vh - 64px - 60px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .waitlist-section {
      min-height: calc(100dvh - 64px - 52px) !important;
      box-sizing: border-box !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: center !important;
      padding: 2rem 1.25rem 1.5rem !important;
    }
  }
</style>
