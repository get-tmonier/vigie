---
import WheelMark from '#components/WheelMark.astro';
---

<section id="waitlist" class="bg-navy-deep py-24 px-10 text-center min-h-[calc(100vh-64px-60px)] box-border flex flex-col justify-center max-md:min-h-[calc(100dvh-64px-52px)] max-md:py-8 max-md:px-5 max-md:pb-6">
  <div class="max-w-[600px] mx-auto">
    <div class="flex justify-center mb-10">
      <WheelMark size={80} />
    </div>

    <h2
      class="font-vollkorn text-slate font-bold text-[clamp(1.4rem,3vw,1.9rem)] m-0 mb-4 leading-[1.35]"
    >
      AI writes the code.
    </h2>

    <p
      class="font-vollkorn-sc text-gold font-bold text-[clamp(1.3rem,3vw,1.8rem)] m-0 mb-6 leading-[1.3]"
    >
      You hold the helm.
    </p>

    <p
      class="font-mono text-cream text-[0.82rem] m-0 mb-8 leading-[1.6]"
    >
      Early adopters get their <span class="text-gold font-semibold">first month free</span> on the Solo plan.
    </p>

    <div class="newsletter-form-container">
      <form
        class="newsletter-form waitlist-form flex gap-3 max-w-[480px] mx-auto mb-4 max-[540px]:flex-col"
        action="https://app.loops.so/api/newsletter-form/cmm61m1au0ws70i1mpmh6f87r"
        method="POST"
      >
        <input
          class="newsletter-form-input font-mono text-cream flex-1 text-[0.85rem] bg-navy-mid/50 border border-gold/25 rounded-[4px] py-[0.8rem] px-4 outline-none min-w-0 transition-colors duration-200 focus:border-gold/60"
          type="email"
          name="newsletter-form-input"
          placeholder="your@email.com"
          required
          autocomplete="email"
        />
        <button
          type="submit"
          class="newsletter-form-button font-mono bg-gold text-navy-deep font-semibold text-[0.85rem] border-none rounded-[4px] py-[0.8rem] px-[1.4rem] cursor-pointer whitespace-nowrap transition-colors duration-200 hover:bg-gold-light"
        >
          Claim your spot
        </button>
        <button
          type="button"
          class="newsletter-loading-button hidden font-mono bg-gold text-navy-deep font-semibold text-[0.85rem] border-none rounded-[4px] py-[0.8rem] px-[1.4rem] whitespace-nowrap opacity-70 cursor-not-allowed"
        >
          Sending…
        </button>
      </form>

      <div class="newsletter-success hidden justify-center items-center p-[0.8rem] mb-4">
        <p class="font-mono text-gold text-[0.82rem] m-0">
          &#10003; You're on the list. We'll be in touch when the beta opens.
        </p>
      </div>

      <div class="newsletter-error hidden justify-center items-center p-[0.8rem] mb-4">
        <p class="newsletter-error-message font-mono text-[0.82rem] text-[#c0392b] m-0">
          Oops! Something went wrong, please try again
        </p>
      </div>

      <button
        class="newsletter-back-button hidden font-mono text-slate text-[0.75rem] bg-transparent border-none cursor-pointer mx-auto mt-2 hover:underline"
        type="button"
      >
        &larr; Back
      </button>
    </div>

    <p class="font-mono text-[0.72rem] text-slate/60 m-0">
      Limited spots — no spam, just your invite when the beta opens.
    </p>
  </div>
</section>

<script>
  function submitHandler(event: SubmitEvent) {
    event.preventDefault();
    const container = (event.target as HTMLElement).parentNode as HTMLElement;
    const form = container.querySelector<HTMLFormElement>('.newsletter-form')!;
    const formInput = container.querySelector<HTMLInputElement>('.newsletter-form-input')!;
    const success = container.querySelector<HTMLElement>('.newsletter-success')!;
    const errorContainer = container.querySelector<HTMLElement>('.newsletter-error')!;
    const errorMessage = container.querySelector<HTMLElement>('.newsletter-error-message')!;
    const backButton = container.querySelector<HTMLButtonElement>('.newsletter-back-button')!;
    const submitButton = container.querySelector<HTMLButtonElement>('.newsletter-form-button')!;
    const loadingButton = container.querySelector<HTMLButtonElement>('.newsletter-loading-button')!;

    const show = (el: HTMLElement) => el.classList.remove('hidden');
    const hide = (el: HTMLElement) => el.classList.add('hidden');

    const rateLimit = () => {
      show(errorContainer);
      errorMessage.innerText = 'Too many signups, please try again in a little while';
      hide(submitButton);
      hide(formInput);
      show(backButton);
    };

    const time = new Date();
    const timestamp = time.valueOf();
    const previousTimestamp = localStorage.getItem('loops-form-timestamp');
    if (previousTimestamp && Number(previousTimestamp) + 60000 > timestamp) {
      rateLimit();
      return;
    }
    localStorage.setItem('loops-form-timestamp', String(timestamp));

    hide(submitButton);
    show(loadingButton);

    const formBody = 'userGroup=&mailingLists=&email=' + encodeURIComponent(formInput.value);

    fetch((event.target as HTMLFormElement).action, {
      method: 'POST',
      body: formBody,
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    })
      .then((res) => Promise.all([res.ok, res.json()]))
      .then(([ok, data]) => {
        if (ok) {
          show(success);
          form.reset();
        } else {
          show(errorContainer);
          errorMessage.innerText = data.message ?? 'Something went wrong';
        }
      })
      .catch((error: Error) => {
        if (error.message === 'Failed to fetch') { rateLimit(); return; }
        show(errorContainer);
        if (error.message) errorMessage.innerText = error.message;
        localStorage.setItem('loops-form-timestamp', '');
      })
      .finally(() => {
        hide(formInput);
        hide(loadingButton);
        show(backButton);
      });
  }

  function resetFormHandler(event: MouseEvent) {
    const container = (event.target as HTMLElement).parentNode as HTMLElement;
    const formInput = container.querySelector<HTMLInputElement>('.newsletter-form-input')!;
    const success = container.querySelector<HTMLElement>('.newsletter-success')!;
    const errorContainer = container.querySelector<HTMLElement>('.newsletter-error')!;
    const errorMessage = container.querySelector<HTMLElement>('.newsletter-error-message')!;
    const backButton = container.querySelector<HTMLButtonElement>('.newsletter-back-button')!;
    const submitButton = container.querySelector<HTMLButtonElement>('.newsletter-form-button')!;

    const show = (el: HTMLElement) => el.classList.remove('hidden');
    const hide = (el: HTMLElement) => el.classList.add('hidden');

    hide(success);
    hide(errorContainer);
    errorMessage.innerText = 'Oops! Something went wrong, please try again';
    hide(backButton);
    show(formInput);
    show(submitButton);
  }

  const formContainers = document.getElementsByClassName('newsletter-form-container');
  for (let i = 0; i < formContainers.length; i++) {
    const container = formContainers[i];
    if (container.classList.contains('newsletter-handlers-added')) continue;
    container.querySelector('.newsletter-form')!.addEventListener('submit', submitHandler as EventListener);
    container.querySelector('.newsletter-back-button')!.addEventListener('click', resetFormHandler as EventListener);
    container.classList.add('newsletter-handlers-added');
  }
</script>
