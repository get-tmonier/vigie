---
import RadarMark from '#components/RadarMark.astro';
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}
const { content } = Astro.props;
const { openSource } = content;
---

<section id="open-source" class="bg-navy-800 py-20 px-10 min-h-screen box-border flex flex-col justify-center">
  <div class="max-w-[720px] mx-auto text-center">
    <h2
      class="font-display text-cream-50 text-[clamp(1.6rem,3vw,2.4rem)] m-0 mb-6 [text-wrap:balance]"
    >
      {openSource.heading}
    </h2>

    <div class="bg-navy-900 rounded-2xl py-10 px-8 mb-10 shadow-[0_2px_4px_rgba(0,0,0,0.1),0_12px_40px_rgba(0,0,0,0.3)]">
      <div class="flex justify-center mb-6">
        <RadarMark size={56} />
      </div>

      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="font-mono text-vigie-400 text-[0.75rem] font-semibold tracking-[0.1em] uppercase bg-vigie-400/10 border border-vigie-400/25 rounded-[4px] py-1 px-3">{openSource.licenseBadge}</span>
      </div>

      <p class="font-display text-cream-50 text-[1.15rem] m-0 mb-3 leading-[1.6] [text-wrap:balance]">
        {openSource.headline}
      </p>
      <p class="font-display text-cream-200 text-[0.95rem] m-0 mb-8 leading-[1.7] max-w-[520px] mx-auto [text-wrap:balance]">
        {openSource.description}
      </p>

      <a
        href="https://github.com/get-tmonier/core"
        class="inline-block font-mono bg-vigie-400 text-navy-900 font-semibold text-[0.85rem] py-3 px-8 rounded-lg no-underline shadow-[0_1px_2px_rgba(0,0,0,0.15),0_4px_12px_rgba(38,192,154,0.2)] transition-all duration-200 hover:bg-vigie-500 hover:shadow-[0_2px_4px_rgba(0,0,0,0.2),0_8px_24px_rgba(38,192,154,0.25)]"
      >
        {openSource.ctaGithub}
      </a>
    </div>

    <!-- BYOA callout -->
    <div class="bg-navy-900 rounded-lg py-5 px-7 mb-8 flex items-center gap-6 flex-wrap justify-center text-left">
      <div>
        <p class="font-display text-cream-50 text-[1.05rem] m-0 mb-1 leading-[1.3] flex items-center gap-[0.6rem]">
          <RadarMark size={20} />
          {openSource.byoaHeadline}
        </p>
        <p class="font-display text-cream-200 text-[0.9rem] m-0 leading-[1.6]">
          {openSource.byoaDescription}
        </p>
      </div>
    </div>

    <p class="font-mono text-cream-200/40 text-[0.7rem] m-0 italic">
      {openSource.agplJoke}
    </p>
  </div>
</section>
