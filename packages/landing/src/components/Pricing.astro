---
import WheelMark from './WheelMark.astro';
const plans = [
  {
    name: 'Free',
    price: 'Free',
    priceEur: null,
    priceUsd: null,
    priceNote: 'forever',
    tagline: 'For engineers who want to see what their agent is actually doing.',
    features: [
      'Local-first — your code stays on your machine, we never store it',
      'Real-time activity — every file touched, every command run',
      'Loop & scope detection — flagged before they burn your session',
      '1 supervised agent',
    ],
    cta: 'Claim your spot',
    ctaHref: '#waitlist',
    featured: false,
  },
  {
    name: 'Solo',
    price: '€4.99',
    priceEur: '€4.99',
    priceUsd: '$5.99',
    priceNote: '/month',
    badge: 'Best value',
    tagline:
      'For power users who want memory that survives compaction and costs that stay under control.',
    features: [
      'Everything in Free, plus:',
      'Checkpoints & rollback — revert to the last clean state and resume with full context, no reprompting',
      'Budget guardrails — alerts before costs spike, never a surprise bill',
      'Compaction-proof memory — decisions persisted locally across context resets',
      'Up to 5 supervised agents',
    ],
    cta: 'Claim your spot',
    ctaHref: '#waitlist',
    featured: true,
  },
  {
    name: 'Team',
    price: '€9.99',
    priceEur: '€9.99',
    priceUsd: '$11.99',
    priceNote: '/seat/month',
    tagline: 'For teams where one agent going off-script affects everyone.',
    features: [
      'Everything in Solo, plus:',
      'Team activity dashboard — who ran what, across the whole team',
      'Cross-agent conflict detection — breaking changes surfaced before review',
      'Shared guardrails — team-wide constraints on every agent, every session',
    ],
    cta: 'Claim your spot',
    ctaHref: '#waitlist',
    featured: false,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    priceEur: null,
    priceUsd: null,
    priceNote: '',
    tagline: 'For organizations that need full control, compliance & dedicated support.',
    features: [
      'Everything in Team, plus:',
      'Self-hosted — your infrastructure, your network, your rules',
      'SLA & dedicated support',
      'SOC2 Type II + DPA',
    ],
    cta: 'Contact us',
    ctaHref: '/contact',
    featured: false,
  },
];
---

<section id="pricing" class="pricing-section" style="background: #F5F0E8; padding: 5rem 2.5rem;">
  <div style="max-width: 1400px; margin: 0 auto;">
    <div style="display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
      <h2
        style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: clamp(1.6rem, 3vw, 2.2rem); color: #0B1A2E; margin: 0;"
      >
        Simple pricing
      </h2>
      <div
        id="currency-toggle"
        style="display: flex; align-items: center; background: #E8E0D0; border-radius: 20px; padding: 3px; gap: 2px; cursor: pointer;"
        role="group"
        aria-label="Currency selector"
      >
        <button
          id="btn-eur"
          data-currency="eur"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 16px; border: none; cursor: pointer; background: #0B1A2E; color: #F5F0E8; transition: all 0.15s;"
        >€ EUR</button>
        <button
          id="btn-usd"
          data-currency="usd"
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 600; padding: 0.25rem 0.65rem; border-radius: 16px; border: none; cursor: pointer; background: transparent; color: #8B9CAF; transition: all 0.15s;"
        >$ USD</button>
      </div>
    </div>

    <!-- BYOA callout -->
    <div
      style="background: #0B1A2E; border-radius: 8px; padding: 1.25rem 1.75rem; margin-bottom: 3rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;"
    >
      <div>
        <p style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: 1.05rem; color: #F5F0E8; margin: 0 0 0.25rem; line-height: 1.3; display: flex; align-items: center; gap: 0.6rem;">
          <WheelMark size={20} />
          No AI token markup — ever.
        </p>
        <p style="font-family: 'Source Serif 4', serif; font-size: 0.9rem; color: #8B9CAF; margin: 0; line-height: 1.6;">
          Your AI subscription. Your machine. Zero middlemen.
        </p>
      </div>
    </div>

    <div
      style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; align-items: start;"
      class="pricing-grid"
    >
      {
        plans.map((plan) => (
          <div
            class="reveal-pricing"
            style={`background: #fff; border-radius: 8px; padding: 2rem; position: relative; ${
              plan.featured
                ? 'border: 2px solid #C49A2B; box-shadow: 0 8px 32px rgba(196,154,43,0.15);'
                : 'border: 1px solid #E8E0D0;'
            }`}
          >
            {plan.badge && (
              <div
                style="position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: #C49A2B; color: #0B1A2E; font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 20px; white-space: nowrap; text-transform: uppercase; letter-spacing: 1px;"
              >
                {plan.badge}
              </div>
            )}

            <div style="margin-bottom: 1.5rem;">
              <h3
                style="font-family: 'Vollkorn SC', serif; font-weight: 700; font-size: 1rem; color: #0B1A2E; margin: 0 0 0.75rem; letter-spacing: 0.05em;"
              >
                {plan.name}
              </h3>
              <div style="display: flex; align-items: baseline; gap: 0.3rem; margin-bottom: 0.6rem;">
                <span
                  class="price-display"
                  data-eur={plan.priceEur ?? plan.price}
                  data-usd={plan.priceUsd ?? plan.price}
                  style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: 2rem; color: #0B1A2E;"
                >
                  {plan.price}
                </span>
                {plan.priceNote && (
                  <span
                    style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #8B9CAF;"
                  >
                    {plan.priceNote}
                  </span>
                )}
              </div>
              {plan.priceEur && (
                <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #B0A898; margin: -0.3rem 0 0.6rem; letter-spacing: 0.03em;">
                  excl. VAT
                </p>
              )}
              <p style="font-family: 'Source Serif 4', serif; font-size: 0.85rem; color: #8B9CAF; margin: 0; line-height: 1.5;">
                {plan.tagline}
              </p>
            </div>

            <ul style="list-style: none; padding: 0; margin: 0 0 2rem;">
              {plan.features.map((f) => {
                const isHeader = f.startsWith('Everything in');
                return (
                  <li
                    style={`padding: 0.4rem 0; border-bottom: 1px solid #F5F0E8; display: flex; align-items: flex-start; gap: 0.5rem; ${
                      isHeader
                        ? "font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; color: #C49A2B; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: none; padding-bottom: 0.2rem;"
                        : "font-family: 'Source Serif 4', serif; font-size: 0.875rem; color: #1D3557;"
                    }`}
                  >
                    {!isHeader && <span style="color: #C49A2B; font-size: 0.75rem; flex-shrink: 0; margin-top: 0.2rem;">&#10003;</span>}
                    {f}
                  </li>
                );
              })}
            </ul>

            <a
              href={plan.ctaHref}
              style={`display: block; text-align: center; font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.8rem; padding: 0.75rem; border-radius: 4px; text-decoration: none; transition: all 0.2s; ${
                plan.featured
                  ? 'background: #C49A2B; color: #0B1A2E;'
                  : 'background: transparent; color: #0B1A2E; border: 1px solid #C49A2B;'
              }`}
              onmouseover={
                plan.featured
                  ? "this.style.background='#D4AA3C'"
                  : "this.style.background='rgba(196,154,43,0.1)'"
              }
              onmouseout={
                plan.featured
                  ? "this.style.background='#C49A2B'"
                  : "this.style.background='transparent'"
              }
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const btnEur = document.getElementById('btn-eur') as HTMLButtonElement;
  const btnUsd = document.getElementById('btn-usd') as HTMLButtonElement;
  const prices = document.querySelectorAll<HTMLElement>('.price-display');

  function setCurrency(currency: 'eur' | 'usd') {
    const isEur = currency === 'eur';
    btnEur.style.background = isEur ? '#0B1A2E' : 'transparent';
    btnEur.style.color = isEur ? '#F5F0E8' : '#8B9CAF';
    btnUsd.style.background = isEur ? 'transparent' : '#0B1A2E';
    btnUsd.style.color = isEur ? '#8B9CAF' : '#F5F0E8';
    prices.forEach((el) => {
      el.textContent = el.dataset[currency] ?? el.textContent;
    });
  }

  btnEur.addEventListener('click', () => setCurrency('eur'));
  btnUsd.addEventListener('click', () => setCurrency('usd'));
</script>

<style>
  .pricing-section {
    min-height: 100vh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr !important;
    }
  }

  .reveal-pricing {
    opacity: 0;
    transform: translateY(30px) scale(0.97);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal-pricing.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  const pricingCards = document.querySelectorAll('.reveal-pricing');
  const pricingObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const card = entry.target as HTMLElement;
        const allCards = Array.from(document.querySelectorAll('.reveal-pricing'));
        const index = allCards.indexOf(card);
        card.style.transitionDelay = `${index * 100}ms`;
        card.classList.add('visible');
        pricingObserver.unobserve(card);
      }
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -60px 0px' });
  pricingCards.forEach((card) => pricingObserver.observe(card));
</script>
