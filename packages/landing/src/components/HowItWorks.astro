---
const steps = [
  {
    number: '01',
    label: 'You see everything, live',
    description:
      "Every file your agent touches, every command it runs — visible in real time. No more wondering what it's up to. No more surprises.",
  },
  {
    number: '02',
    label: 'Tmonier flags anything off',
    description:
      'Loop detected. Scope violated. Budget exceeded. Deterministic rules on observable signals — not an LLM judging an LLM.',
    signals: ['File loops', 'Command repetition', 'Scope drift', 'Context bloat'],
  },
  {
    number: '03',
    label: 'You call the shots',
    description:
      'Your checkpoints, your call. Correct course, approve, or stop. One unified diff to review. Approve once, merge once. The helm is yours.',
  },
];
---

<section
  id="how-it-works"
  class="hiw-section"
  style="background: #0B1A2E; padding: 5rem 2.5rem;"
>
  <div style="max-width: 900px; margin: 0 auto;">

    <div style="margin-bottom: 3.5rem; text-align: center;">
      <p
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: #C49A2B; margin: 0 0 1rem;"
      >
        How it works
      </p>
      <h2
        style="font-family: 'Vollkorn SC', serif; font-size: clamp(1.8rem, 4vw, 2.8rem); color: #F5F0E8; margin: 0 0 0.75rem; line-height: 1.2;"
      >
        Watch. Know. Decide.
      </h2>
      <p
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: #8B9CAF; margin: 0;"
      >
        Three steps. You're never flying blind.
      </p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 2rem;">
      {
        steps.map((step) => (
          <div
            style="display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: start; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(196, 154, 43, 0.12); border-radius: 8px; padding: 2rem;"
            class="hiw-block"
          >
            <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem; min-width: 60px;">
              <span
                style="font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 1.5rem; color: #C49A2B; line-height: 1;"
              >
                {step.number}
              </span>
            </div>
            <div>
              <h3
                style="font-family: 'Vollkorn', serif; font-weight: 700; font-size: 1.2rem; color: #F5F0E8; margin: 0 0 0.6rem; line-height: 1.3;"
              >
                {step.label}
              </h3>
              <p
                style={`font-family: 'Source Serif 4', serif; font-size: 0.95rem; color: #8B9CAF; line-height: 1.75; margin: 0${step.signals ? ' 0 1rem' : ''};`}
              >
                {step.description}
              </p>
              {step.signals && (
                <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                  {step.signals.map((s) => (
                    <span
                      style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; font-weight: 600; color: #C49A2B; letter-spacing: 0.08em; text-transform: uppercase; background: rgba(196,154,43,0.08); border: 1px solid rgba(196,154,43,0.2); border-radius: 4px; padding: 0.25rem 0.6rem;"
                    >
                      {s}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>

  </div>
</section>

<style>
  .hiw-section {
    min-height: 100vh;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .hiw-block {
      grid-template-columns: 1fr !important;
      gap: 1rem !important;
    }
  }
</style>
