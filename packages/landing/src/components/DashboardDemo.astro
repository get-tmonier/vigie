---
---

<section
  id="dashboard-demo"
  class="dashboard-section bg-navy-deep px-6 pb-8 overflow-hidden"
>
  <!-- Browser UI mockup -->
  <div
    class="browser-mock opacity-0 translate-y-6 max-w-[920px] mx-auto rounded-xl overflow-hidden border border-gold/20 shadow-[0_32px_80px_rgba(0,0,0,0.5)]"
  >
    <!-- Browser chrome -->
    <div class="bg-navy-mid/70 py-[0.65rem] px-4 flex items-center gap-2 border-b border-gold/10">
      <!-- macOS traffic-light colors — kept as inline per convention -->
      <span style="width: 12px; height: 12px; background: #FF5F57; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <span style="width: 12px; height: 12px; background: #FFBD2E; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <span style="width: 12px; height: 12px; background: #28C840; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <!-- Address bar -->
      <div class="flex-1 mx-3 bg-navy-deep/70 border border-slate/15 rounded-md py-1 px-3 flex items-center gap-[0.4rem] max-w-[320px] ml-auto mr-auto">
        <svg width="10" height="12" viewBox="0 0 10 12" fill="none" class="shrink-0 opacity-50">
          <path d="M5 0C3.067 0 1.5 1.567 1.5 3.5V5H1C0.448 5 0 5.448 0 6v5c0 .552.448 1 1 1h8c.552 0 1-.448 1-1V6c0-.552-.448-1-1-1H8.5V3.5C8.5 1.567 6.933 0 5 0zm2.5 5h-5V3.5C2.5 2.12 3.62 1 5 1s2.5 1.12 2.5 2.5V5z" fill="#8B9CAF"/>
        </svg>
        <span class="font-mono text-[0.65rem] text-slate/60">app.tmonier.com</span>
      </div>
    </div>

    <!-- Browser body -->
    <div class="browser-body flex bg-navy-deep/50">
      <!-- Sidebar -->
      <div class="browser-sidebar w-[180px] shrink-0 bg-navy-deep/60 border-r border-gold/10 py-5">
        <!-- Logo -->
        <div class="px-4 pb-5 border-b border-slate/10 mb-4">
          <div class="flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="46" stroke="#C49A2B" stroke-width="4"/>
              <circle cx="50" cy="50" r="8" fill="#C49A2B"/>
              <line x1="50" y1="4" x2="50" y2="20" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="50" y1="80" x2="50" y2="96" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="4" y1="50" x2="20" y2="50" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="80" y1="50" x2="96" y2="50" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="18" y1="18" x2="29" y2="29" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="71" y1="71" x2="82" y2="82" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="82" y1="18" x2="71" y2="29" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="29" y1="71" x2="18" y2="82" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
            </svg>
            <span class="font-mono text-[0.78rem] text-gold font-semibold">tmonier</span>
          </div>
        </div>
        <!-- Nav items -->
        <nav class="px-3 flex flex-col gap-[0.15rem]">
          <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md bg-gold/8 border border-gold/15">
            <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
            <span class="font-mono text-[0.7rem] text-cream">Agents</span>
          </div>
          <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md">
            <span class="w-[6px] h-[6px] rounded-full inline-block shrink-0"></span>
            <span class="font-mono text-[0.7rem] text-slate">Runs</span>
          </div>
          <div class="flex items-center gap-[0.6rem] py-[0.45rem] px-[0.6rem] rounded-md">
            <span class="w-[6px] h-[6px] rounded-full inline-block shrink-0"></span>
            <span class="font-mono text-[0.7rem] text-slate">Settings</span>
          </div>
        </nav>
      </div>

      <!-- Main area -->
      <div class="flex-1 p-5 bg-navy-deep/40 min-w-0 relative min-h-[420px]">
        <!-- Header row -->
        <div class="flex items-center justify-between mb-4 gap-2">
          <span class="font-mono text-[0.7rem] text-cream font-semibold">Rate-limit /api/users</span>
          <div class="flex items-center gap-[0.6rem]">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; background: rgba(40,200,64,0.12); color: #28C840; border: 1px solid rgba(40,200,64,0.3); border-radius: 10px; padding: 0.1rem 0.55rem;">1 agent active</span>
            <span class="cost-counter font-mono text-[0.65rem] text-slate">$0.00</span>
          </div>
        </div>

        <!-- Agent card -->
        <div
          class="agent-card opacity-0 bg-navy-mid/50 rounded-lg p-3 mb-4"
          style="border: 1px solid rgba(40,200,64,0.3);"
        >
          <div class="agent-header flex items-center justify-between mb-[0.4rem]">
            <div class="flex items-center gap-[0.35rem]">
              <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block;"></span>
              <span class="font-mono text-[0.7rem] text-gold font-semibold">Claude Code</span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.5rem; background: rgba(139,156,175,0.1); border: 1px solid rgba(139,156,175,0.2); border-radius: 4px; padding: 0.05rem 0.35rem; color: #8B9CAF;">opus</span>
            </div>
            <span class="agent-file font-mono text-[0.6rem] text-slate/60">src/middleware/rate-limit.ts</span>
          </div>
          <!-- Context window gauge -->
          <div class="flex items-center gap-2 mt-[0.55rem]">
            <span class="font-mono text-[0.5rem] text-slate/50 shrink-0">context</span>
            <div class="flex-1 h-[3px] bg-slate/15 rounded-sm overflow-hidden relative">
              <div class="context-bar" style="height: 100%; width: 0; border-radius: 2px; transition: width 1.5s ease-out, background 0.5s ease; background: #28C840;"></div>
            </div>
            <span class="context-pct font-mono text-[0.5rem] text-slate/50 shrink-0 min-w-[2.2em] text-right">0%</span>
            <span class="context-action" style="opacity: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.48rem; color: #FF8C42; flex-shrink: 0; cursor: default; border-bottom: 1px dotted rgba(255,140,66,0.4); transition: opacity 0.4s ease;">fresh window from checkpoint</span>
          </div>
        </div>

        <!-- Activity log -->
        <div class="bg-navy-deep/50 border border-slate/10 rounded-md py-[0.6rem] px-3 mb-3">
          <div class="font-mono text-[0.55rem] tracking-[0.08em] uppercase text-slate/40 mb-2">Activity</div>
          <div class="log-container flex flex-col gap-1 h-[130px] overflow-y-hidden"></div>
        </div>

        <!-- Action panel — appears after loop detection -->
        <div
          class="action-panel opacity-0 translate-y-2 bg-navy-mid/40 border border-gold/30 rounded-lg p-3"
        >
          <!-- Panel header -->
          <div class="flex items-center justify-between mb-[0.6rem]">
            <div class="flex items-center gap-[0.4rem]">
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #FFBD2E; font-weight: 700;">&#9888;</span>
              <span class="font-mono text-[0.62rem] text-cream font-semibold">Agent paused &mdash; loop detected</span>
            </div>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #FF8C42;">$4.20 spent</span>
          </div>

          <!-- Suggested prompt -->
          <div class="bg-navy-deep/60 border border-slate/15 rounded-md py-[0.55rem] px-[0.65rem] mb-[0.6rem]">
            <div class="font-mono text-[0.5rem] tracking-[0.08em] uppercase text-slate/40 mb-[0.3rem]">Suggested prompt</div>
            <p class="suggested-prompt-text font-mono text-[0.6rem] text-cream m-0 leading-[1.6] italic min-h-[1.6em]"></p>
          </div>

          <!-- Action buttons -->
          <div class="flex gap-[0.35rem] justify-end">
            <div
              class="action-btn-rollback opacity-0 flex items-center gap-[0.3rem] font-mono text-[0.58rem] bg-gold/12 border border-gold/35 rounded-[5px] py-[0.35rem] px-[0.6rem] text-gold font-semibold cursor-default"
            >
              <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="shrink-0">
                <path d="M2 8a6 6 0 1 1 1.76 4.24" stroke="#C49A2B" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M2 4v4h4" stroke="#C49A2B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Rollback #3
            </div>
            <div
              class="action-btn-send"
              style="opacity: 0; display: flex; align-items: center; gap: 0.3rem; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; background: rgba(40,200,64,0.1); border: 1px solid rgba(40,200,64,0.3); border-radius: 5px; padding: 0.35rem 0.6rem; color: #28C840; font-weight: 600; cursor: default;"
            >
              <svg width="10" height="10" viewBox="0 0 16 16" fill="none" class="shrink-0">
                <path d="M2 8h12M10 4l4 4-4 4" stroke="#28C840" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Resume
            </div>
            <div
              class="action-btn-stop"
              style="opacity: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; background: rgba(255,95,87,0.08); border: 1px solid rgba(255,95,87,0.25); border-radius: 5px; padding: 0.35rem 0.6rem; color: rgba(255,95,87,0.7); cursor: default;"
            >
              Stop agent
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Websocket connector + terminal: single wrapper, fades in together so line never shows without terminal -->
  <div class="ws-connector opacity-0 flex flex-col items-center mt-6">
    <!-- Inner div: line is absolute here so it stops at the top of the terminal -->
    <div class="relative flex flex-col items-center w-full">
      <div
        class="ws-dash absolute left-1/2 top-0 bottom-0 -translate-x-1/2 w-[2px]"
        style="background: repeating-linear-gradient(to bottom, rgba(40,200,64,0.3) 0px, rgba(40,200,64,0.3) 4px, transparent 4px, transparent 8px);"
      ></div>
      <!-- Badge — floats over the line -->
      <div class="relative z-10 py-[52px]">
        <div style="display: flex; align-items: center; gap: 0.4rem; background: rgba(40,200,64,0.07); border: 1px solid rgba(40,200,64,0.25); border-radius: 20px; padding: 0.25rem 0.75rem;">
          <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block; flex-shrink: 0; animation: ws-pulse 2s ease-in-out infinite;"></span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.52rem; color: #28C840; letter-spacing: 0.04em;">ws://localhost:4800</span>
        </div>
      </div>
    </div>

    <!-- Local daemon terminal: sibling to the line wrapper, so the line stops here -->
    <div
      class="local-terminal max-w-[520px] w-full rounded-[10px] overflow-hidden border border-slate/15 shadow-[0_16px_48px_rgba(0,0,0,0.3)]"
    >
    <!-- Window chrome -->
    <div class="bg-navy-mid/50 py-[0.55rem] px-[0.85rem] flex gap-[0.45rem] items-center border-b border-slate/10">
      <!-- macOS traffic-light colors — kept as inline per convention -->
      <span style="width: 10px; height: 10px; background: #FF5F57; border-radius: 50%; display: inline-block;"></span>
      <span style="width: 10px; height: 10px; background: #FFBD2E; border-radius: 50%; display: inline-block;"></span>
      <span style="width: 10px; height: 10px; background: #28C840; border-radius: 50%; display: inline-block;"></span>
      <span class="font-mono text-[0.6rem] text-slate/40 ml-[0.4rem]">zsh — ~/projects/my-app</span>
    </div>
    <!-- Terminal content -->
    <div class="bg-navy-deep/60 py-4 px-5 font-mono text-[0.68rem] leading-[2]">
      <div>
        <span class="text-gold">$</span>
        <span class="text-gold-pale"> tmonier start</span>
      </div>
      <div class="text-slate">
        <span style="color: #28C840;">&#10003;</span> daemon running on localhost:4800
      </div>
      <div class="text-slate/50">
        watching claude-code · all events forwarded to dashboard
      </div>
      <div class="text-slate/35 text-[0.58rem] mt-[0.15rem]">
        local-first &mdash; your data never leaves your machine
      </div>
      <div class="mt-[0.35rem]">
        <span class="text-gold">$</span>
        <span style="display: inline-block; width: 7px; height: 1em; background: #C49A2B; margin-left: 4px; vertical-align: text-bottom; animation: blink 1.2s step-end infinite;"></span>
      </div>
    </div>
    </div><!-- /local-terminal -->
  </div><!-- /ws-connector -->
</section>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse-amber {
    0%, 100% { border-color: rgba(255,189,46,0.3); }
    50%      { border-color: rgba(255,189,46,0.6); box-shadow: 0 0 12px 0 rgba(255,189,46,0.1); }
  }

  /* Browser mock entrance */
  .dashboard-section.is-visible .browser-mock {
    animation: fade-up 0.3s ease-out forwards;
  }

  /* Agent card */
  .dashboard-section.is-visible .agent-card {
    animation: fade-in 0.2s ease-out 0.15s forwards;
  }

  /* Log lines — animated via JS */

  /* Action panel & buttons — animated via JS */

  /* Blink cursor */
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0; }
  }

  /* Connector + terminal appear together after action panel */
  .dashboard-section.is-visible .ws-connector {
    animation: fade-in 0.3s ease-out 5s forwards;
  }
  .dashboard-section.is-visible .ws-dash {
    animation: ws-flow 0.6s linear infinite;
  }
  @keyframes ws-flow {
    to { background-position: 0 8px; }
  }
  @keyframes ws-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }


  /* Responsive */
  @media (max-width: 768px) {
    .browser-body {
      flex-direction: column !important;
    }
    .browser-sidebar {
      display: none !important;
    }
    .agent-card {
      padding: 0.6rem !important;
    }
    .agent-card .agent-header {
      flex-direction: column !important;
      align-items: flex-start !important;
      gap: 0.25rem !important;
    }
    .agent-file {
      font-size: 0.52rem !important;
      word-break: break-all;
    }
    .context-action {
      display: none !important;
    }
    .action-panel {
      padding: 0.6rem !important;
    }
    .log-line {
      font-size: 0.55rem !important;
    }
    .local-terminal {
      max-width: 100% !important;
    }
    .ws-connector {
      margin-top: 1rem !important;
    }
  }
</style>

<script>
  const section = document.getElementById('dashboard-demo');
  if (section) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');

            const container = section.querySelector<HTMLElement>('.log-container');
            if (!container) return;

            // Log data — each line injected dynamically like a real terminal
            const logs: { time: string; html: string; delay: number }[] = [
              { time: '14:32:01', html: '<span style="color:#8B9CAF">claude-code</span> · reading <span style="color:#28C840">src/api/users.ts</span>', delay: 200 },
              { time: '14:33:12', html: '<span style="color:#8B9CAF">claude-code</span> · created <span style="color:#28C840">src/middleware/rate-limit.ts</span>', delay: 350 },
              { time: '14:34:30', html: '<span style="color:#8B9CAF">claude-code</span> · running <span style="color:#F5F0E8">npm test</span> — <span style="color:#FF5F57">3 failed</span>', delay: 550 },
              { time: '14:35:15', html: '<span style="color:#8B9CAF">claude-code</span> · editing <span style="color:#F5F0E8">src/middleware/rate-limit.ts</span>', delay: 250 },
              { time: '14:36:48', html: '<span style="color:#8B9CAF">claude-code</span> · running <span style="color:#F5F0E8">npm test</span> — <span style="color:#FF5F57">3 failed</span>', delay: 600 },
              { time: '14:37:02', html: '<span style="color:#FFBD2E">⚠ scope drift · <span style="color:rgba(255,189,46,0.7)">agent modified package.json — outside declared scope</span></span>', delay: 400 },
              { time: '14:37:45', html: '<span style="color:#FF8C42">⚠ context 65% · <span style="color:rgba(255,140,66,0.7)">agent may lose early instructions — consider a checkpoint</span></span>', delay: 300 },
              { time: '14:38:01', html: '<span style="color:#8B9CAF">$ cost hint · <span style="color:rgba(139,156,175,0.7)">this task could run on <span style="color:#F5F0E8">sonnet</span> — ~3x cheaper for similar results</span></span>', delay: 200 },
              { time: '14:38:03', html: '<span style="color:#FFBD2E">⚠ loop detected · <span style="color:rgba(255,189,46,0.7)">edit → test → fail → edit — 4 cycles in 6 min</span></span>', delay: 500 },
            ];

            const lineStyle = "font-family:'JetBrains Mono',monospace;font-size:0.62rem;line-height:1.8;color:rgba(139,156,175,0.55);display:flex;gap:0.5rem;align-items:baseline";

            let elapsed = 300;
            logs.forEach((log) => {
              elapsed += log.delay;
              const t = elapsed;
              setTimeout(() => {
                const div = document.createElement('div');
                div.className = 'log-line';
                div.style.cssText = lineStyle;
                div.innerHTML = `<span style="color:rgba(139,156,175,0.35);flex-shrink:0">${log.time}</span><span>${log.html}</span>`;
                container.appendChild(div);
                // Auto-scroll to bottom
                container.scrollTop = container.scrollHeight;
              }, t);
            });

            const loopDetectedTime = elapsed;

            // --- Agent card border turns amber when loop detected ---
            setTimeout(() => {
              const card = section.querySelector<HTMLElement>('.agent-card');
              if (card) {
                card.style.transition = 'border-color 0.4s ease';
                card.style.borderColor = 'rgba(255,189,46,0.4)';
              }
            }, loopDetectedTime);

            // --- Action panel slides in after loop detected ---
            const panel = section.querySelector<HTMLElement>('.action-panel');
            if (panel) {
              setTimeout(() => {
                panel.style.transition = 'opacity 0.3s ease-out, transform 0.3s ease-out';
                panel.style.opacity = '1';
                panel.style.transform = 'translateY(0)';
                panel.style.animation = 'pulse-amber 2.5s ease-in-out 0.3s infinite';
              }, loopDetectedTime + 500);
            }

            // --- Stream suggested prompt like LLM token output ---
            const promptEl = section.querySelector<HTMLElement>('.suggested-prompt-text');
            if (promptEl) {
              const promptText = '\u201cTests expect a Redis mock \u2014 use ioredis-mock in the test setup instead of connecting to a real instance.\u201d';
              // Split into "tokens" (small word groups, like LLM streaming)
              const words = promptText.split(' ');
              const tokens: string[] = [];
              for (let i = 0; i < words.length; i += 2) {
                tokens.push(words.slice(i, i + 2).join(' '));
              }
              let tokenIdx = 0;
              const streamStart = loopDetectedTime + 600;
              const streamToken = () => {
                if (tokenIdx >= tokens.length) {
                  // Remove cursor after streaming done
                  const cursor = promptEl.querySelector('.stream-cursor');
                  if (cursor) cursor.remove();
                  return;
                }
                promptEl.textContent = (promptEl.textContent || '') + (tokenIdx > 0 ? ' ' : '') + tokens[tokenIdx];
                // Add blinking cursor at end
                let cursor = promptEl.querySelector('.stream-cursor') as HTMLElement;
                if (!cursor) {
                  cursor = document.createElement('span');
                  cursor.className = 'stream-cursor';
                  cursor.style.cssText = 'display:inline-block;width:5px;height:0.85em;background:#F5F0E8;margin-left:2px;vertical-align:text-bottom;animation:blink 0.6s step-end infinite;opacity:0.7';
                }
                promptEl.appendChild(cursor);
                tokenIdx++;
                // Variable delay per token (20-60ms per token, like real streaming)
                setTimeout(streamToken, 80 + Math.random() * 120);
              };
              setTimeout(streamToken, streamStart);
            }

            // Action buttons staggered after panel
            const btnRollback = section.querySelector<HTMLElement>('.action-btn-rollback');
            const btnSend = section.querySelector<HTMLElement>('.action-btn-send');
            const btnStop = section.querySelector<HTMLElement>('.action-btn-stop');
            [btnRollback, btnSend, btnStop].forEach((btn, i) => {
              if (btn) {
                setTimeout(() => {
                  btn.style.transition = 'opacity 0.15s ease-out';
                  btn.style.opacity = '1';
                }, loopDetectedTime + 700 + i * 100);
              }
            });

            // --- Context window bar: synced with log progression ---
            const ctxBar = section.querySelector<HTMLElement>('.context-bar');
            const ctxPct = section.querySelector<HTMLElement>('.context-pct');
            if (ctxBar && ctxPct) {
              const ctxSteps = [
                { delay: 550,   width: '18', pct: '18%', color: '#28C840' },
                { delay: 1100,  width: '31', pct: '31%', color: '#28C840' },
                { delay: 1350,  width: '44', pct: '44%', color: '#FFBD2E' },
                { delay: 1950,  width: '57', pct: '57%', color: '#FFBD2E' },
                { delay: loopDetectedTime, width: '65', pct: '65%', color: '#FF8C42' },
              ];
              for (const step of ctxSteps) {
                setTimeout(() => {
                  ctxBar.style.width = step.width + '%';
                  ctxBar.style.background = step.color;
                  ctxPct.textContent = step.pct;
                  ctxPct.style.color = step.color;
                }, step.delay);
              }
              const ctxAction = section.querySelector<HTMLElement>('.context-action');
              if (ctxAction) {
                setTimeout(() => { ctxAction.style.opacity = '1'; }, loopDetectedTime + 100);
              }
            }

            // --- Cost counter: synced with log progression ---
            const costEl = section.querySelector<HTMLElement>('.cost-counter');
            if (costEl) {
              const costSteps = [
                { delay: 550,   value: '$0.40', color: '' },
                { delay: 1100,  value: '$1.12', color: '' },
                { delay: 1350,  value: '$2.30', color: '#FFBD2E' },
                { delay: 1950,  value: '$3.45', color: '#FF8C42' },
                { delay: loopDetectedTime, value: '$4.20', color: '#FF8C42' },
              ];
              for (const step of costSteps) {
                setTimeout(() => {
                  costEl.textContent = step.value;
                  if (step.color) costEl.style.color = step.color;
                }, step.delay);
              }
            }

            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  }
</script>
