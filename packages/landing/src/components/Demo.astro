---
---

<section
  id="demo"
  class="demo-section"
  style="background: var(--navy-deep); padding: 6rem 1.5rem; overflow: hidden;"
>
  <!-- ① Header -->
  <div style="text-align: center; max-width: 720px; margin: 0 auto 4rem;">
    <p
      style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); margin: 0 0 1rem;"
    >
      See it in action
    </p>
    <h2
      style="font-family: 'Vollkorn SC', serif; font-size: clamp(1.8rem, 4vw, 2.8rem); color: var(--cream); margin: 0 0 1rem; line-height: 1.2;"
    >
      Your agents, orchestrated
    </h2>
    <p style="font-family: 'Source Serif 4', serif; font-size: 1.05rem; color: var(--slate); margin: 0; line-height: 1.7;">
      Tmonier gives you one dashboard for every agent — progress, conflicts, and decisions, all in real time.
    </p>
  </div>

  <!-- ② Browser UI mockup -->
  <div
    class="browser-mock"
    style="opacity: 0; transform: translateY(24px); max-width: 860px; margin: 0 auto 3rem; border-radius: 12px; overflow: hidden; border: 1px solid rgba(196,154,43,0.2); box-shadow: 0 32px 80px rgba(0,0,0,0.5);"
  >
    <!-- Browser chrome -->
    <div
      style="background: rgba(29,53,87,0.7); padding: 0.65rem 1rem; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(196,154,43,0.1);"
    >
      <span style="width: 12px; height: 12px; background: #FF5F57; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <span style="width: 12px; height: 12px; background: #FFBD2E; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <span style="width: 12px; height: 12px; background: #28C840; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
      <!-- Address bar -->
      <div
        style="flex: 1; margin: 0 0.75rem; background: rgba(11,26,46,0.7); border: 1px solid rgba(139,156,175,0.15); border-radius: 6px; padding: 0.25rem 0.75rem; display: flex; align-items: center; gap: 0.4rem; max-width: 320px; margin-left: auto; margin-right: auto;"
      >
        <svg width="10" height="12" viewBox="0 0 10 12" fill="none" style="flex-shrink: 0; opacity: 0.5;">
          <path d="M5 0C3.067 0 1.5 1.567 1.5 3.5V5H1C0.448 5 0 5.448 0 6v5c0 .552.448 1 1 1h8c.552 0 1-.448 1-1V6c0-.552-.448-1-1-1H8.5V3.5C8.5 1.567 6.933 0 5 0zm2.5 5h-5V3.5C2.5 2.12 3.62 1 5 1s2.5 1.12 2.5 2.5V5z" fill="#8B9CAF"/>
        </svg>
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(139,156,175,0.6);">app.tmonier.com/run/add-oauth2</span>
      </div>
    </div>

    <!-- Browser body -->
    <div class="browser-body" style="display: flex; background: rgba(11,26,46,0.5); min-height: 340px;">
      <!-- Sidebar -->
      <div
        class="browser-sidebar"
        style="width: 200px; flex-shrink: 0; background: rgba(11,26,46,0.6); border-right: 1px solid rgba(196,154,43,0.1); padding: 1.25rem 0;"
      >
        <!-- Logo -->
        <div style="padding: 0 1.25rem 1.25rem; border-bottom: 1px solid rgba(139,156,175,0.1); margin-bottom: 1rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <svg width="18" height="18" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="50" cy="50" r="46" stroke="#C49A2B" stroke-width="4"/>
              <circle cx="50" cy="50" r="8" fill="#C49A2B"/>
              <line x1="50" y1="4" x2="50" y2="20" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="50" y1="80" x2="50" y2="96" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="4" y1="50" x2="20" y2="50" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="80" y1="50" x2="96" y2="50" stroke="#C49A2B" stroke-width="4" stroke-linecap="round"/>
              <line x1="18" y1="18" x2="29" y2="29" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="71" y1="71" x2="82" y2="82" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="82" y1="18" x2="71" y2="29" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
              <line x1="29" y1="71" x2="18" y2="82" stroke="#C49A2B" stroke-width="3.5" stroke-linecap="round"/>
            </svg>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--gold); font-weight: 600;">tmonier</span>
          </div>
        </div>
        <!-- Nav items -->
        <nav style="padding: 0 0.75rem; display: flex; flex-direction: column; gap: 0.15rem;">
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; border-radius: 6px; background: rgba(196,154,43,0.08); border: 1px solid rgba(196,154,43,0.15);">
            <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--cream);">Agents</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; border-radius: 6px;">
            <span style="width: 6px; height: 6px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--slate);">Runs</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; border-radius: 6px;">
            <span style="width: 6px; height: 6px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--slate);">Memory</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.6rem; border-radius: 6px;">
            <span style="width: 6px; height: 6px; border-radius: 50%; display: inline-block; flex-shrink: 0;"></span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--slate);">Settings</span>
          </div>
        </nav>
      </div>

      <!-- Main area -->
      <div style="flex: 1; padding: 1.25rem; background: rgba(11,26,46,0.4); min-width: 0;">
        <!-- Header row -->
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--cream); font-weight: 600;">Add OAuth2 flow</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; background: rgba(40,200,64,0.12); color: #28C840; border: 1px solid rgba(40,200,64,0.3); border-radius: 10px; padding: 0.1rem 0.55rem;">3 agents active</span>
        </div>

        <!-- Agent cards grid -->
        <div class="browser-agents" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 1rem;">
          <!-- Agent 1: Building -->
          <div
            class="agent-card-1"
            style="opacity: 0; background: rgba(29,53,87,0.5); border: 1px solid rgba(40,200,64,0.3); border-radius: 8px; padding: 0.75rem;"
          >
            <div style="display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.3rem;">
              <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block;"></span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--gold);">Agent 1</span>
            </div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--cream); font-weight: 600; margin-bottom: 0.15rem;">auth-service</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: rgba(139,156,175,0.5); margin-bottom: 0.6rem;">OAuth2 provider + token lifecycle</div>
            <div style="height: 3px; background: rgba(139,156,175,0.15); border-radius: 2px; overflow: hidden;">
              <div class="agent-bar" data-width="85" style="height: 100%; width: 0; background: #28C840; border-radius: 2px; transition: width 0.9s ease-out;"></div>
            </div>
          </div>

          <!-- Agent 2: Waiting -->
          <div
            class="agent-card-2"
            style="opacity: 0; background: rgba(29,53,87,0.5); border: 1px solid rgba(196,154,43,0.3); border-radius: 8px; padding: 0.75rem;"
          >
            <div style="display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.3rem;">
              <span style="width: 6px; height: 6px; background: #FFBD2E; border-radius: 50%; display: inline-block;"></span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--gold);">Agent 2</span>
            </div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--cream); font-weight: 600; margin-bottom: 0.15rem;">api-gateway</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #FFBD2E; margin-bottom: 0.6rem;">awaiting your approval</div>
            <div style="height: 3px; background: rgba(139,156,175,0.15); border-radius: 2px; overflow: hidden;">
              <div class="agent-bar" data-width="60" style="height: 100%; width: 0; background: #FFBD2E; border-radius: 2px; transition: width 0.9s ease-out;"></div>
            </div>
          </div>

          <!-- Agent 3: Done -->
          <div
            class="agent-card-3"
            style="opacity: 0; background: rgba(29,53,87,0.5); border: 1px solid rgba(139,156,175,0.2); border-radius: 8px; padding: 0.75rem;"
          >
            <div style="display: flex; align-items: center; gap: 0.35rem; margin-bottom: 0.3rem;">
              <span style="width: 6px; height: 6px; background: #28C840; border-radius: 50%; display: inline-block;"></span>
              <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--gold);">Agent 3</span>
            </div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--cream); font-weight: 600; margin-bottom: 0.15rem;">test-suite</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: #28C840; margin-bottom: 0.6rem;">&#10003; complete — 24 tests passing</div>
            <div style="height: 3px; background: rgba(139,156,175,0.15); border-radius: 2px; overflow: hidden;">
              <div class="agent-bar" data-width="100" style="height: 100%; width: 0; background: #28C840; border-radius: 2px; transition: width 0.9s ease-out;"></div>
            </div>
          </div>
        </div>

        <!-- Activity log -->
        <div style="background: rgba(11,26,46,0.5); border: 1px solid rgba(139,156,175,0.1); border-radius: 6px; padding: 0.6rem 0.75rem;">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; line-height: 1.9; color: rgba(139,156,175,0.55);">
            <span style="color: rgba(139,156,175,0.35);">14:32:01</span> agent-1 · building OAuth2 provider in <span style="color: var(--gold);">worktree/auth</span><br/>
            <span style="color: rgba(139,156,175,0.35);">14:32:04</span> agent-2 · modified <span style="color: var(--cream);">auth.ts</span> — checking against agent-1's interface contract… <span style="color: #28C840;">OK</span><br/>
            <span style="color: rgba(139,156,175,0.35);">14:32:07</span> <span style="color: #FFBD2E;">conflict</span> · agent-2 wants to change token format — <span style="color: #FFBD2E;">awaiting your decision</span><br/>
            <span style="color: rgba(139,156,175,0.35);">14:32:11</span> agent-3 · test suite complete — 24/24 passing
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ③ Architectural Memory panel -->
  <div style="max-width: 480px; margin: 0 auto 3.5rem;">
    <div
      class="sub-panel-right"
      style="opacity: 0; transform: translateY(24px); background: rgba(29,53,87,0.25); border: 1px solid rgba(139,156,175,0.2); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 64px rgba(0,0,0,0.4);"
    >
      <div style="background: rgba(29,53,87,0.5); padding: 0.65rem 1rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(139,156,175,0.15);">
        <div>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: rgba(139,156,175,0.5); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.1rem;">Architectural Memory</div>
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--slate);">shared across all agents</div>
        </div>
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; background: rgba(196,154,43,0.15); color: var(--gold); border: 1px solid rgba(196,154,43,0.3); border-radius: 4px; padding: 0.1rem 0.5rem;">enforced</span>
      </div>
      <div style="padding: 1rem;">
        <!-- Card 1: CONSTRAINT -->
        <div
          class="cq-card-1"
          style="opacity: 0; border: 1px solid rgba(196,154,43,0.4); border-radius: 8px; padding: 0.75rem; margin-bottom: 0.75rem; background: rgba(196,154,43,0.04);"
        >
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; color: var(--gold);">CONSTRAINT</span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: rgba(139,156,175,0.5);">all agents</span>
          </div>
          <p style="font-family: 'Source Serif 4', serif; font-size: 0.78rem; color: var(--cream); margin: 0; line-height: 1.5;">
            Service boundary: auth module owns all token lifecycle. Do not duplicate in API gateway.
          </p>
        </div>

        <!-- Card 2: DECISION -->
        <div
          class="cq-card-2"
          style="opacity: 0; border: 1px solid rgba(139,156,175,0.3); border-radius: 8px; padding: 0.75rem; background: rgba(139,156,175,0.04);"
        >
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; color: var(--slate);">DECISION</span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: rgba(139,156,175,0.5);">sprint 14</span>
          </div>
          <p style="font-family: 'Source Serif 4', serif; font-size: 0.78rem; color: var(--cream); margin: 0; line-height: 1.5;">
            Use JWT with 15min TTL for session tokens. Refresh tokens stored server-side only.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ④ Orchestration pipeline -->
  <div style="max-width: 1100px; margin: 0 auto;">
    <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(139,156,175,0.5); text-align: center; margin: 0 0 1.5rem;">
      Orchestration pipeline
    </p>
    <div
      class="pipeline-row"
      style="display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;"
    >
      <!-- Node 1: Spec -->
      <div class="pipe-node pipe-n1" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(196,154,43,0.5); background: rgba(196,154,43,0.1); color: var(--gold); border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap; font-weight: 600;">
          Spec
        </div>
        <span class="pipe-arrow" style="color: rgba(139,156,175,0.4); margin: 0 0.35rem;">&rarr;</span>
      </div>
      <!-- Node 2: Spec & Decompose -->
      <div class="pipe-node pipe-n2" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(139,156,175,0.3); background: rgba(139,156,175,0.06); color: var(--slate); border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap;">
          Spec &amp; Decompose
        </div>
        <span class="pipe-arrow" style="color: rgba(139,156,175,0.4); margin: 0 0.35rem;">&rarr;</span>
      </div>
      <!-- Node 3: You Approve -->
      <div class="pipe-node pipe-n3" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(196,154,43,0.6); background: rgba(196,154,43,0.12); color: var(--gold); border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap; font-weight: 600;">
          You Approve
        </div>
        <span class="pipe-arrow" style="color: rgba(139,156,175,0.4); margin: 0 0.35rem;">&rarr;</span>
      </div>
      <!-- Node 4: N Agents Build -->
      <div class="pipe-node pipe-n4" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(42,74,127,0.7); background: rgba(42,74,127,0.15); color: var(--cream); border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap;">
          N Agents Build
        </div>
        <span class="pipe-arrow" style="color: rgba(139,156,175,0.4); margin: 0 0.35rem;">&rarr;</span>
      </div>
      <!-- Node 5: Validate & Merge -->
      <div class="pipe-node pipe-n5" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(139,156,175,0.3); background: rgba(139,156,175,0.06); color: var(--slate); border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap;">
          Validate &amp; Merge
        </div>
        <span class="pipe-arrow" style="color: rgba(139,156,175,0.4); margin: 0 0.35rem;">&rarr;</span>
      </div>
      <!-- Node 6: Done -->
      <div class="pipe-node pipe-n6" style="opacity: 0; display: flex; align-items: center;">
        <div style="border: 1px solid rgba(40,200,64,0.5); background: rgba(40,200,64,0.1); color: #28C840; border-radius: 6px; padding: 0.45rem 0.85rem; white-space: nowrap; font-weight: 600;">
          Done
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1);   box-shadow: 0 0 0 0   rgba(196, 154, 43, 0.5); }
    50%       { transform: scale(1.3); box-shadow: 0 0 0 5px rgba(196, 154, 43, 0); }
  }

  /* Browser mock entrance */
  .demo-section.is-visible .browser-mock {
    animation: fade-up 0.6s ease-out 0s forwards;
  }

  /* Agent cards staggered */
  .demo-section.is-visible .agent-card-1 { animation: fade-up 0.5s ease-out 0.1s forwards; }
  .demo-section.is-visible .agent-card-2 { animation: fade-up 0.5s ease-out 0.2s forwards; }
  .demo-section.is-visible .agent-card-3 { animation: fade-up 0.5s ease-out 0.3s forwards; }

  /* Architectural Memory panel */
  .demo-section.is-visible .sub-panel-right { animation: fade-up 0.6s ease-out 0.2s forwards; }

  /* Memory cards */
  .demo-section.is-visible .cq-card-1 { animation: fade-up 0.5s ease-out 0.3s forwards; }
  .demo-section.is-visible .cq-card-2 { animation: fade-up 0.5s ease-out 0.6s forwards; }

  /* Pipeline nodes */
  .demo-section.is-visible .pipe-n1 { animation: fade-up 0.4s ease-out 0.50s forwards; }
  .demo-section.is-visible .pipe-n2 { animation: fade-up 0.4s ease-out 0.75s forwards; }
  .demo-section.is-visible .pipe-n3 { animation: fade-up 0.4s ease-out 1.00s forwards; }
  .demo-section.is-visible .pipe-n4 { animation: fade-up 0.4s ease-out 1.25s forwards; }
  .demo-section.is-visible .pipe-n5 { animation: fade-up 0.4s ease-out 1.50s forwards; }
  .demo-section.is-visible .pipe-n6 { animation: fade-up 0.4s ease-out 1.75s forwards; }

  /* Responsive */
  @media (max-width: 768px) {
    .browser-agents    { grid-template-columns: 1fr !important; }
    .browser-body      { flex-direction: column !important; }
    .browser-sidebar   { width: 100% !important; border-right: none !important; border-bottom: 1px solid rgba(196,154,43,0.1); }
    .pipeline-row      { flex-direction: column !important; align-items: center !important; }
    .pipe-node         { flex-direction: column !important; align-items: center !important; }
    .pipe-arrow        { transform: rotate(90deg); margin: 0.25rem 0 !important; }
  }
</style>

<script>
  const section = document.getElementById('demo');
  if (section) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            section.classList.add('is-visible');
            setTimeout(() => {
              document.querySelectorAll('.agent-bar').forEach((bar) => {
                const width = bar.getAttribute('data-width');
                if (width) {
                  (bar as HTMLElement).style.width = width + '%';
                }
              });
            }, 800);
            observer.unobserve(section);
          }
        });
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  }
</script>
