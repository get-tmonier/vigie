---
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}
const { content } = Astro.props;
const { toolsStrip } = content;

const availableTools = ['Claude Code'];
---

<section class="bg-navy-900 py-5 px-10 border-t border-b border-vigie-400/8">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex items-center gap-4 flex-wrap">
      <p class="font-mono text-[0.68rem] tracking-[3px] text-cream-200/45 uppercase whitespace-nowrap shrink-0 m-0 min-w-[6rem]">
        {toolsStrip.label}
      </p>
      <div class="flex gap-[0.6rem] flex-wrap items-center">
        {availableTools.map((t) => (
          <span class="font-mono text-[0.72rem] font-medium text-cream-50/85 bg-vigie-400/10 border border-vigie-400/25 rounded-[4px] py-[0.3rem] px-[0.7rem] whitespace-nowrap">
            {t}
          </span>
        ))}
        <span class="font-mono text-[0.65rem] text-cream-200/40 pl-1" set:html={toolsStrip.comingSoon}></span>
      </div>
    </div>
  </div>
</section>
