---
import { Picture } from 'astro:assets';
import helmsmanImg from '#assets/helmsman.jpg';
import WheelMark from '#components/WheelMark.astro';
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
  locale: string;
}

const { content, locale } = Astro.props;
const { hero, origin } = content;
---

<section
  class="relative min-h-[calc(100vh-64px)] box-border flex flex-col justify-center py-10 px-10 overflow-hidden max-md:pb-4 max-md:px-5 max-md:-mt-16 max-md:pt-16 max-md:min-h-svh"
  style="background: radial-gradient(ellipse at 60% 110%, color-mix(in srgb, var(--gold) 6%, transparent) 0%, transparent 60%), var(--navy-deep)"
>
  <div class="max-w-[920px] mx-auto w-full grid grid-cols-[1fr_280px] gap-5 items-center max-md:flex max-md:flex-col max-md:gap-5 max-md:text-center">
    <!-- Left: text content — dominant -->
    <div>
      <!-- WheelMark + company name — fades in first -->
      <div id="hero-brand" class="flex items-center gap-3 mb-5 opacity-0 max-md:justify-center max-md:flex-wrap">
        <div class="flex items-center gap-3">
          <div class="animate-[spin-slow_30s_linear_infinite]">
            <WheelMark size={42} />
          </div>
          <span class="font-vollkorn-sc text-gold font-bold text-[1.4rem] tracking-[0.03em]">
            {hero.name}
          </span>
        </div>
        <span class="text-gold/30">·</span>
        <span class="font-source-serif text-gold/60 italic text-[0.85rem] tracking-wide">
          {hero.tagline}
        </span>
      </div>

      <!-- Full name — typed letter by letter -->
      <h1 class="font-vollkorn text-cream font-bold text-[clamp(3rem,6vw,4.5rem)] m-0 mb-3 leading-[1.05] tracking-[-0.02em] min-h-[1.15em] max-md:min-h-[1.2em] max-md:mb-1">
        <span id="hero-name"></span><span id="hero-name-cursor" class="inline-block w-[3px] bg-gold opacity-0 animate-[blink_0.8s_step-end_infinite] align-middle" style="height: 0.75em; margin-left: 10px; margin-bottom: 0.05em;"></span>
      </h1>

      <!-- Role — typed with mono effect -->
      <p class="font-source-serif text-slate text-[clamp(1.1rem,2.2vw,1.4rem)] m-0 mb-8 leading-[1.5] min-h-[1.5em] max-md:min-h-[3em]">
        <span id="hero-role"></span>
      </p>

      <!-- CTAs — slide up -->
      <div id="hero-ctas" class="flex gap-4 items-center flex-wrap opacity-0 max-md:justify-center max-md:flex-col max-md:items-stretch max-md:gap-3" style="transition: opacity 0.5s ease;">
        <a
          href={locale === 'fr' ? '/fr/contact' : '/contact'}
          class="font-mono bg-gold text-navy-deep font-semibold text-[0.85rem] py-3.5 px-7 rounded-[4px] no-underline transition-colors duration-200 inline-block hover:bg-gold-light max-md:block max-md:text-center"
        >
          {hero.ctaPrimary}
        </a>
        <a
          href="#experience"
          class="font-mono text-gold font-semibold text-[0.85rem] py-3.5 px-7 rounded-[4px] no-underline border border-gold/40 transition-all duration-200 inline-block hover:bg-gold/10 hover:border-gold/60 max-md:block max-md:text-center"
        >
          {hero.ctaSecondary}
        </a>
      </div>
    </div>

    <!-- Right: mascotte + definition plaque -->
    <div class="flex flex-col items-center gap-0 max-md:flex-row max-md:items-stretch max-md:gap-0 max-md:h-[150px] max-md:w-full max-md:max-w-[380px] max-md:mx-auto">
      <!-- Image — reveals with clip-path from top -->
      <div
        id="hero-image"
        class="relative inline-block rounded-t-xl border-2 border-b-0 border-gold/20 overflow-hidden w-full max-h-[300px] max-md:w-[120px] max-md:max-h-none max-md:rounded-l-xl max-md:rounded-tr-none max-md:border-r-0 max-md:border-b-2 max-md:border-b-gold/20 max-md:shrink-0"
        style="clip-path: inset(100% 0 0 0); transition: clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);"
      >
        <Picture
          src={helmsmanImg}
          alt="The Helmsman — Tmonier mascotte"
          formats={['avif', 'webp']}
          widths={[280, 440]}
          sizes="(max-width: 768px) 120px, 280px"
          quality={80}
          loading="eager"
          fetchpriority="high"
          class="block w-full h-full object-cover scale-[1.15] origin-[center_20%] max-md:scale-[1.3] max-md:object-[center_15%]"
        />
      </div>

      <!-- Definition plaque — slides up + fades in after image -->
      <div
        id="hero-plaque"
        class="w-full border-2 border-gold/20 border-t border-t-gold/10 rounded-b-xl bg-gold/4 pt-2.5 px-3.5 pb-2.5 opacity-0 max-md:max-w-none max-md:w-auto max-md:flex-1 max-md:min-w-0 max-md:rounded-r-xl max-md:rounded-tl-none max-md:rounded-bl-none max-md:py-2 max-md:px-3 max-md:flex max-md:flex-col max-md:justify-center max-md:border-t-2 max-md:border-t-gold/20 max-md:border-l max-md:border-l-gold/10"
        style="transform: translateY(12px); transition: opacity 0.5s ease 0s, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0s;"
      >
        <div id="hero-plaque-name" class="flex items-baseline gap-2 flex-wrap mb-1 opacity-0" style="transition: opacity 0.3s ease;">
          <span class="font-vollkorn-sc text-gold font-black text-[1rem]">tmonier</span>
          <span class="font-mono text-[0.65rem] text-slate/60">{origin.pronunciation}</span>
        </div>
        {origin.grammar && <p id="hero-plaque-grammar" class="font-mono text-[0.52rem] text-gold/40 tracking-[0.1em] uppercase m-0 mb-1 opacity-0" style="transition: opacity 0.3s ease;">{origin.grammar}</p>}
        <p id="hero-plaque-def" class="font-source-serif text-[0.78rem] text-slate/75 leading-[1.55] m-0 opacity-0" style="transition: opacity 0.4s ease;">
          {origin.definition}
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ fullName: hero.fullName, oneLiner: hero.oneLiner }}>
  // Orchestrated hero entrance animation
  const brand = document.getElementById('hero-brand');
  const nameEl = document.getElementById('hero-name');
  const nameCursor = document.getElementById('hero-name-cursor');
  const roleEl = document.getElementById('hero-role');
  const ctas = document.getElementById('hero-ctas');

  if (brand && nameEl && nameCursor && roleEl && ctas) {
    let t = 300;

    // Phase 1: Brand line fades in (WheelMark + Tmonier + tagline)
    setTimeout(() => {
      brand.style.transition = 'opacity 0.6s ease';
      brand.style.opacity = '1';
    }, t);
    t += 500;

    // Phase 2: Name types letter by letter with variable speed
    nameCursor.style.opacity = '1';
    let charIdx = 0;
    function typeName() {
      if (charIdx < fullName.length) {
        const ch = fullName[charIdx];
        const span = document.createElement('span');
        if (ch === ' ') {
          span.innerHTML = '&nbsp;';
        } else {
          span.textContent = ch;
        }
        span.style.opacity = '0';
        span.style.display = 'inline-block';
        span.style.transform = ch === ' ' ? 'none' : 'translateY(8px)';
        span.style.transition = 'opacity 0.2s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1)';
        nameEl.appendChild(span);
        // Trigger animation next frame
        requestAnimationFrame(() => {
          span.style.opacity = '1';
          span.style.transform = 'translateY(0)';
        });
        charIdx++;
        // Variable timing: space = pause, otherwise random
        const delay = ch === ' ' ? 120 : (30 + Math.random() * 50);
        setTimeout(typeName, delay);
      } else {
        // Name complete — brief pause then hide cursor
        setTimeout(() => {
          nameCursor.style.transition = 'opacity 0.3s ease';
          nameCursor.style.opacity = '0';
          typeRole();
        }, 400);
      }
    }
    setTimeout(typeName, t);
    t += fullName.length * 55 + 500;

    // Phase 3: Role words appear with stagger
    function typeRole() {
      const words = oneLiner.split(' ');
      let wordDelay = 0;
      words.forEach((word, i) => {
        setTimeout(() => {
          const span = document.createElement('span');
          span.textContent = (i > 0 ? ' ' : '') + word;
          span.style.opacity = '0';
          span.style.display = 'inline';
          span.style.transition = 'opacity 0.3s ease';
          roleEl.appendChild(span);
          requestAnimationFrame(() => {
            span.style.opacity = '1';
          });
        }, wordDelay);
        wordDelay += 60;
      });

      // Phase 4: CTAs slide up after role is done
      setTimeout(() => {
        ctas.style.opacity = '1';
      }, wordDelay + 200);
    }

    // Phase 5: Image reveals with clip-path curtain (overlaps with name typing)
    const heroImage = document.getElementById('hero-image');
    const heroPlaque = document.getElementById('hero-plaque');
    const plaqueName = document.getElementById('hero-plaque-name');
    const plaqueGrammar = document.getElementById('hero-plaque-grammar');
    const plaqueDef = document.getElementById('hero-plaque-def');

    // Image curtain reveal
    setTimeout(() => {
      if (heroImage) heroImage.style.clipPath = 'inset(0 0 0 0)';
    }, 800);

    // Plaque slides up
    setTimeout(() => {
      if (heroPlaque) {
        heroPlaque.style.opacity = '1';
        heroPlaque.style.transform = 'translateY(0)';
      }
    }, 1500);

    // Plaque content cascades
    setTimeout(() => {
      if (plaqueName) plaqueName.style.opacity = '1';
    }, 1700);
    setTimeout(() => {
      if (plaqueGrammar) plaqueGrammar.style.opacity = '1';
    }, 1850);
    setTimeout(() => {
      if (plaqueDef) plaqueDef.style.opacity = '1';
    }, 2000);
  }
</script>
