---
import { Image } from 'astro:assets';
import helmsmanImg from '../assets/helmsman.png';
---

<section
  class="hero-section"
  style="background: radial-gradient(ellipse at 60% 110%, rgba(196, 154, 43, 0.08) 0%, transparent 60%), #0B1A2E; padding: 5rem 2.5rem 6rem;"
>
  <div
    style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;"
    class="hero-grid"
  >
    <!-- Left: text -->
    <div class="hero-left">
      <p
        class="hero-tagline"
        style="font-family: 'JetBrains Mono', monospace; font-weight: 500; font-size: 0.7rem; letter-spacing: 4px; color: rgba(196, 154, 43, 0.6); text-transform: uppercase; margin: 0 0 1.5rem;"
      >
        You hold the helm.
      </p>

      <h1
        class="hero-heading"
        style="font-family: 'Vollkorn SC', serif; font-weight: 900; font-size: clamp(2.2rem, 4.5vw, 3.2rem); color: #C49A2B; margin: 0 0 1.5rem; line-height: 1.15; letter-spacing: -0.01em;"
      >
        Ship 10x faster.<br />Break nothing.
      </h1>

      <p
        class="hero-body"
        style="font-family: 'Source Serif 4', serif; font-weight: 400; font-size: 1.1rem; color: #8B9CAF; line-height: 1.8; margin: 0 0 2.5rem; max-width: 500px;"
      >
        You design. The AI agents crew executes.<br />Nothing merges without your signal.
      </p>

      <div class="hero-buttons" style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
        <a
          class="hero-btn"
          href="#waitlist"
          style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.875rem; background: #C49A2B; color: #0B1A2E; padding: 0.85rem 1.8rem; border-radius: 4px; text-decoration: none; transition: background 0.2s; display: inline-block;"
          onmouseover="this.style.background='#D4AA3C'"
          onmouseout="this.style.background='#C49A2B'"
        >
          Claim your spot — 3 months free
        </a>
        <a
          class="hero-btn"
          href="/see-in-action"
          style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.875rem; color: #C49A2B; border: 2px solid rgba(196, 154, 43, 0.5); padding: 0.8rem 1.6rem; border-radius: 4px; text-decoration: none; transition: background 0.2s, border-color 0.2s; display: inline-block;"
          onmouseover="this.style.background='rgba(196,154,43,0.1)';this.style.borderColor='#C49A2B'"
          onmouseout="this.style.background='transparent';this.style.borderColor='rgba(196,154,43,0.5)'"
        >
          See it in action &rarr;
        </a>
      </div>
    </div>

    <!-- Right: mascotte + definition plaque -->
    <div class="hero-right" style="display: flex; flex-direction: column; align-items: center; gap: 0;">
      <div
        class="hero-mascotte-frame"
        style="position: relative; display: inline-block; border-radius: 12px 12px 0 0; border: 2px solid rgba(196, 154, 43, 0.2); border-bottom: none; overflow: hidden; max-width: 320px; width: 100%; aspect-ratio: 1568 / 2000;"
      >
        <Image
          src={helmsmanImg}
          alt="The Helmsman — Tmonier mascotte"
          width={704}
          format="webp"
          loading="eager"
          fetchpriority="high"
          style="display: block; width: 100%; height: 100%; object-fit: cover; transform: scale(1.15); transform-origin: center 20%;"
        />
      </div>

      <!-- Definition plaque -->
      <div
        class="hero-plaque"
        style="max-width: 320px; width: 100%; border: 2px solid rgba(196, 154, 43, 0.2); border-top: 1px solid rgba(196, 154, 43, 0.1); border-radius: 0 0 12px 12px; background: rgba(196, 154, 43, 0.04); padding: 1.1rem 1.4rem 1.2rem;"
      >
        <div style="display: flex; align-items: baseline; gap: 0.65rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
          <span style="font-family: 'Vollkorn SC', serif; font-weight: 900; font-size: 1.05rem; color: #C49A2B;">tmonier</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(139, 156, 175, 0.6);">/ti.mɔ.nje/</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(196, 154, 43, 0.45); letter-spacing: 0.1em; text-transform: uppercase;">n. French</span>
        </div>
        <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: rgba(139, 156, 175, 0.25); margin: 0 0 0.4rem; letter-spacing: 0.02em;">alt. Timonier</p>
        <p style="font-family: 'Source Serif 4', serif; font-size: 0.82rem; color: rgba(139, 156, 175, 0.8); line-height: 1.65; margin: 0;">
          The helmsman — the person at the helm who steers the ship while the crew executes.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - 64px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 768px) {
    /* Section fills exactly the viewport below the nav spacer */
    .hero-section {
      height: calc(100dvh - 64px) !important;
      padding: 1rem 1.25rem 0.75rem !important;
      box-sizing: border-box !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: hidden !important;
    }

    /* Stack vertically, center the group as a whole */
    .hero-grid {
      display: flex !important;
      flex-direction: column !important;
      flex: 1 !important;
      grid-template-columns: unset !important;
      gap: 1.75rem !important;
      min-height: 0 !important;
      justify-content: center !important;
      align-items: stretch !important;
    }

    /* Text block — natural size, no grow */
    .hero-left {
      flex-shrink: 0 !important;
    }

    .hero-tagline {
      margin: 0 0 0.8rem !important;
    }
    .hero-heading {
      margin: 0 0 0.4rem !important;
      font-size: 1.7rem !important;
    }
    .hero-body {
      margin: 0 0 3.5rem !important;
      font-size: 0.85rem !important;
      line-height: 1.4 !important;
    }

    .hero-buttons {
      flex-direction: column !important;
      align-items: stretch !important;
      gap: 0.45rem !important;
    }
    .hero-btn {
      display: block !important;
      width: 100% !important;
      text-align: center !important;
      box-sizing: border-box !important;
      padding: 0.65rem 1.2rem !important;
      font-size: 0.78rem !important;
    }

    /* Mascotte block — side by side: image left, plaque right */
    .hero-right {
      flex-shrink: 0 !important;
      flex-direction: row !important;
      align-items: stretch !important;
      justify-content: center !important;
      gap: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      height: 180px !important;
    }

    .hero-mascotte-frame {
      width: 140px !important;
      max-width: 140px !important;
      flex-shrink: 0 !important;
      border-radius: 12px 0 0 12px !important;
      border-right: none !important;
      border-bottom: 2px solid rgba(196, 154, 43, 0.2) !important;
      overflow: hidden !important;
      background: #0B1A2E !important;
    }
    .hero-mascotte-frame img {
      height: 100% !important;
      width: 100% !important;
      object-fit: cover !important;
      object-position: top center !important;
    }

    .hero-plaque {
      max-width: none !important;
      width: auto !important;
      flex: 1 !important;
      min-width: 0 !important;
      border-radius: 0 12px 12px 0 !important;
      border-top: 2px solid rgba(196, 154, 43, 0.2) !important;
      border-left: 1px solid rgba(196, 154, 43, 0.1) !important;
      padding: 0.6rem 0.75rem !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: center !important;
    }
    .hero-plaque span {
      font-size: 0.7rem !important;
    }
    .hero-plaque p {
      font-size: 0.65rem !important;
      line-height: 1.45 !important;
      margin: 0 !important;
    }
    .hero-plaque p:first-of-type {
      display: none !important;
    }
  }
</style>
