---
import { Image } from 'astro:assets';
import helmsmanImg from '#assets/helmsman.png';
---

<section
  class="hero-section min-h-[calc(100vh-64px)] box-border flex flex-col justify-center py-20 px-10 pb-24 max-md:h-[calc(100dvh-64px)] max-md:py-4 max-md:px-5 max-md:pb-3 max-md:overflow-hidden"
  style="background: radial-gradient(ellipse at 60% 110%, color-mix(in srgb, var(--gold) 8%, transparent) 0%, transparent 60%), var(--navy-deep)"
>
  <div
    class="hero-grid max-w-[1200px] mx-auto grid grid-cols-2 gap-16 items-center max-md:flex max-md:flex-col max-md:flex-1 max-md:gap-7 max-md:min-h-0 max-md:justify-center max-md:items-stretch"
  >
    <!-- Left: text -->
    <div class="hero-left max-md:shrink-0">
      <p
        class="hero-tagline font-mono font-medium text-[0.7rem] tracking-[4px] text-gold/80 uppercase m-0 mb-6 max-md:m-0 max-md:mb-[0.8rem]"
      >
        You hold the helm.
      </p>

      <h1
        class="hero-heading font-vollkorn-sc text-gold font-black text-[clamp(2.2rem,4.5vw,3.2rem)] m-0 mb-5 leading-[1.15] tracking-[-0.01em] max-md:m-0 max-md:mb-[0.35rem] max-md:text-[1.7rem]"
      >
        Your crew.<br />Under your watch.
      </h1>

      <p
        class="hero-subtitle font-mono text-slate font-medium text-[0.85rem] m-0 mb-5 max-md:m-0 max-md:mb-2 max-md:text-[0.72rem]"
      >
        You launched the agent. Now what?
      </p>

      <div class="hero-body m-0 mb-10 max-w-[500px] max-md:m-0 max-md:mb-5">
        <div class="border-l-2 border-gold/30 pl-4 m-0 mb-5 flex flex-col gap-[0.4rem]">
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0 max-md:text-[0.78rem] max-md:leading-[1.4]">Looping for an hour. You had no idea.</p>
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0 max-md:text-[0.78rem] max-md:leading-[1.4]">It opened your auth layer. You never asked.</p>
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0 max-md:text-[0.78rem] max-md:leading-[1.4]">$180 in token usage. Still not done.</p>
        </div>
        <p class="font-source-serif text-slate font-normal text-[1.05rem] leading-[1.6] m-0 max-md:text-[0.78rem] max-md:leading-[1.4]">Tmonier shows you — in real time. When something's off, you're the one who catches it.</p>
      </div>

      <div class="hero-buttons flex gap-4 items-center flex-wrap max-md:flex-col max-md:items-stretch max-md:gap-[0.45rem]">
        <a
          class="hero-btn font-mono bg-gold text-navy-deep font-semibold text-sm py-[0.85rem] px-[1.8rem] rounded-[4px] no-underline transition-colors duration-200 inline-block hover:bg-gold-light max-md:block max-md:w-full max-md:text-center max-md:py-[0.65rem] max-md:px-[1.2rem] max-md:text-[0.78rem]"
          href="#waitlist"
        >
          Claim your spot
        </a>
      </div>
    </div>

    <!-- Right: mascotte + definition plaque -->
    <div class="hero-right flex flex-col items-center gap-0 max-md:shrink-0 max-md:flex-row max-md:items-stretch max-md:justify-center max-md:gap-0 max-md:m-0 max-md:p-0 max-md:h-[180px]">
      <div
        class="hero-mascotte-frame relative inline-block rounded-t-xl border-2 border-b-0 border-gold/20 overflow-hidden max-w-[320px] w-full aspect-[1568/2000] max-md:w-[140px] max-md:max-w-[140px] max-md:shrink-0 max-md:rounded-l-xl max-md:rounded-tr-none max-md:rounded-br-none max-md:border-r-0 max-md:border-b-2 max-md:border-b-gold/20 max-md:bg-navy-deep max-md:aspect-auto"
      >
        <Image
          src={helmsmanImg}
          alt="The Helmsman — Tmonier mascotte"
          width={704}
          format="webp"
          loading="eager"
          fetchpriority="high"
          sizes="(max-width: 768px) 140px, 320px"
          class="block w-full h-full object-cover scale-[1.15] origin-[center_20%] max-md:h-full max-md:w-full max-md:object-cover max-md:object-[top_center] max-md:scale-100 max-md:origin-center"
        />
      </div>

      <!-- Definition plaque -->
      <div
        class="hero-plaque max-w-[320px] w-full border-2 border-gold/20 border-t border-t-gold/10 rounded-b-xl bg-gold/4 pt-[1.1rem] px-[1.4rem] pb-[1.2rem] max-md:max-w-none max-md:w-auto max-md:flex-1 max-md:min-w-0 max-md:rounded-r-xl max-md:rounded-tl-none max-md:rounded-bl-none max-md:py-[0.6rem] max-md:px-3 max-md:flex max-md:flex-col max-md:justify-center max-md:border-t-2 max-md:border-t-gold/20 max-md:border-l max-md:border-l-gold/10"
      >
        <div class="flex items-baseline gap-[0.65rem] flex-wrap mb-1">
          <span class="font-vollkorn-sc text-gold font-black text-[1.05rem] max-md:text-[0.7rem]">tmonier</span>
          <span class="font-mono text-[0.72rem] text-slate/60 max-md:text-[0.7rem]">/ti.mɔ.nje/</span>
          <span class="font-mono text-[0.65rem] text-gold/45 tracking-[0.1em] uppercase max-md:text-[0.7rem]">n. French</span>
        </div>
        <p class="font-mono text-[0.6rem] text-slate/50 m-0 mb-[0.4rem] tracking-[0.02em] max-md:hidden">alt. Timonier</p>
        <p class="font-source-serif text-[0.82rem] text-slate/80 leading-[1.65] m-0 max-md:text-[0.65rem] max-md:leading-[1.45] max-md:m-0">
          The helmsman — the person at the helm who steers the ship while the crew executes.
        </p>
      </div>
    </div>
  </div>
</section>
