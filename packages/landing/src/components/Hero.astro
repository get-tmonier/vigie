---
import { Image } from 'astro:assets';
import helmsmanImg from '#assets/helmsman.png';
---

<section
  class="hero-section py-20 px-10 pb-24"
>
  <div
    class="hero-grid max-w-[1200px] mx-auto grid grid-cols-2 gap-16 items-center"
  >
    <!-- Left: text -->
    <div class="hero-left">
      <p
        class="hero-tagline font-mono font-medium text-[0.7rem] tracking-[4px] text-gold/60 uppercase m-0 mb-6"
      >
        You hold the helm.
      </p>

      <h1
        class="hero-heading font-vollkorn-sc text-gold font-black text-[clamp(2.2rem,4.5vw,3.2rem)] m-0 mb-5 leading-[1.15] tracking-[-0.01em]"
      >
        Your crew.<br />Under your watch.
      </h1>

      <p
        class="hero-subtitle font-mono text-slate font-medium text-[0.85rem] m-0 mb-5"
      >
        You launched the agent. Now what?
      </p>

      <div class="hero-body m-0 mb-10 max-w-[500px]">
        <div class="border-l-2 border-gold/30 pl-4 m-0 mb-5 flex flex-col gap-[0.4rem]">
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0">Looping for an hour. You had no idea.</p>
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0">It opened your auth layer. You never asked.</p>
          <p class="font-source-serif font-normal text-[1.05rem] text-slate/60 leading-[1.4] m-0">$180 in token usage. Still not done.</p>
        </div>
        <p class="font-source-serif text-slate font-normal text-[1.05rem] leading-[1.6] m-0">Tmonier shows you — in real time. When something's off, you're the one who catches it.</p>
      </div>

      <div class="hero-buttons flex gap-4 items-center flex-wrap">
        <a
          class="hero-btn font-mono bg-gold text-navy-deep font-semibold text-sm py-[0.85rem] px-[1.8rem] rounded-[4px] no-underline transition-colors duration-200 inline-block hover:bg-gold-light"
          href="#waitlist"
        >
          Claim your spot
        </a>
      </div>
    </div>

    <!-- Right: mascotte + definition plaque -->
    <div class="hero-right flex flex-col items-center gap-0">
      <div
        class="hero-mascotte-frame relative inline-block rounded-t-xl border-2 border-b-0 border-gold/20 overflow-hidden max-w-[320px] w-full aspect-[1568/2000]"
      >
        <Image
          src={helmsmanImg}
          alt="The Helmsman — Tmonier mascotte"
          width={704}
          format="webp"
          loading="eager"
          fetchpriority="high"
          class="block w-full h-full object-cover scale-[1.15] origin-[center_20%]"
        />
      </div>

      <!-- Definition plaque -->
      <div
        class="hero-plaque max-w-[320px] w-full border-2 border-gold/20 border-t border-t-gold/10 rounded-b-xl bg-gold/4 pt-[1.1rem] px-[1.4rem] pb-[1.2rem]"
      >
        <div class="flex items-baseline gap-[0.65rem] flex-wrap mb-1">
          <span class="font-vollkorn-sc text-gold font-black text-[1.05rem]">tmonier</span>
          <span class="font-mono text-[0.72rem] text-slate/60">/ti.mɔ.nje/</span>
          <span class="font-mono text-[0.65rem] text-gold/45 tracking-[0.1em] uppercase">n. French</span>
        </div>
        <p class="font-mono text-[0.6rem] text-slate/25 m-0 mb-[0.4rem] tracking-[0.02em]">alt. Timonier</p>
        <p class="font-source-serif text-[0.82rem] text-slate/80 leading-[1.65] m-0">
          The helmsman — the person at the helm who steers the ship while the crew executes.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - 64px);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: radial-gradient(ellipse at 60% 110%, color-mix(in srgb, var(--gold) 8%, transparent) 0%, transparent 60%), var(--navy-deep);
  }

  @media (max-width: 768px) {
    /* Section fills exactly the viewport below the nav spacer */
    .hero-section {
      height: calc(100dvh - 64px) !important;
      padding: 1rem 1.25rem 0.75rem !important;
      box-sizing: border-box !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: hidden !important;
    }

    /* Stack vertically, center the group as a whole */
    .hero-grid {
      display: flex !important;
      flex-direction: column !important;
      flex: 1 !important;
      grid-template-columns: unset !important;
      gap: 1.75rem !important;
      min-height: 0 !important;
      justify-content: center !important;
      align-items: stretch !important;
    }

    /* Text block — natural size, no grow */
    .hero-left {
      flex-shrink: 0 !important;
    }

    .hero-tagline {
      margin: 0 0 0.8rem !important;
    }
    .hero-heading {
      margin: 0 0 0.35rem !important;
      font-size: 1.7rem !important;
    }
    .hero-subtitle {
      margin: 0 0 0.5rem !important;
      font-size: 0.72rem !important;
    }
    .hero-body {
      margin: 0 0 1.25rem !important;
    }
    .hero-body p {
      font-size: 0.78rem !important;
      line-height: 1.4 !important;
    }
    .hero-pill {
      margin-top: 0.5rem !important;
      font-size: 0.62rem !important;
    }

    .hero-buttons {
      flex-direction: column !important;
      align-items: stretch !important;
      gap: 0.45rem !important;
    }
    .hero-btn {
      display: block !important;
      width: 100% !important;
      text-align: center !important;
      box-sizing: border-box !important;
      padding: 0.65rem 1.2rem !important;
      font-size: 0.78rem !important;
    }

    /* Mascotte block — side by side: image left, plaque right */
    .hero-right {
      flex-shrink: 0 !important;
      flex-direction: row !important;
      align-items: stretch !important;
      justify-content: center !important;
      gap: 0 !important;
      margin: 0 !important;
      padding: 0 !important;
      height: 180px !important;
    }

    .hero-mascotte-frame {
      width: 140px !important;
      max-width: 140px !important;
      flex-shrink: 0 !important;
      border-radius: 12px 0 0 12px !important;
      border-right: none !important;
      border-bottom: 2px solid color-mix(in srgb, var(--gold) 20%, transparent) !important;
      overflow: hidden !important;
      background: var(--navy-deep) !important;
    }
    .hero-mascotte-frame img {
      height: 100% !important;
      width: 100% !important;
      object-fit: cover !important;
      object-position: top center !important;
    }

    .hero-plaque {
      max-width: none !important;
      width: auto !important;
      flex: 1 !important;
      min-width: 0 !important;
      border-radius: 0 12px 12px 0 !important;
      border-top: 2px solid color-mix(in srgb, var(--gold) 20%, transparent) !important;
      border-left: 1px solid color-mix(in srgb, var(--gold) 10%, transparent) !important;
      padding: 0.6rem 0.75rem !important;
      display: flex !important;
      flex-direction: column !important;
      justify-content: center !important;
    }
    .hero-plaque span {
      font-size: 0.7rem !important;
    }
    .hero-plaque p {
      font-size: 0.65rem !important;
      line-height: 1.45 !important;
      margin: 0 !important;
    }
    .hero-plaque p:first-of-type {
      display: none !important;
    }
  }
</style>
