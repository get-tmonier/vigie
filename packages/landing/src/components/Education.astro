---
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { education } = content;

const langLevels: Record<string, number> = {
  native: 100,
  'langue maternelle': 100,
  fluent: 85,
  courant: 85,
  intermediate: 50,
  'interm\u00e9diaire': 50,
};

function getLevel(lang: string): number {
  const lower = lang.toLowerCase();
  for (const [key, val] of Object.entries(langLevels)) {
    if (lower.includes(key)) return val;
  }
  return 30;
}
---

<section class="bg-navy-deep py-10 px-10 max-md:py-8 max-md:px-5">
  <div class="max-w-[800px] mx-auto">
    <div class="reveal-up flex items-center justify-between flex-wrap gap-6 max-md:flex-col max-md:gap-4" style="--delay: 0ms">
      <!-- Education — compact inline -->
      <div class="flex items-center gap-4">
        <div class="size-10 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.66 2.69 3 6 3s6-1.34 6-3v-5"/>
          </svg>
        </div>
        <div>
          <p class="font-vollkorn-sc text-gold font-bold text-[0.9rem] m-0 leading-tight">{education.degree}</p>
          <p class="font-source-serif text-slate text-[0.78rem] m-0">
            {education.school} · {education.period} · <span class="text-gold/80 font-mono text-[0.65rem] font-semibold uppercase">{education.distinction}</span>
          </p>
        </div>
      </div>

      <!-- Languages — inline pills with bars -->
      <div class="flex items-center gap-3">
        {education.languages.map((lang) => {
          const name = lang.split('(')[0].trim();
          const level = getLevel(lang);
          return (
            <div class="flex items-center gap-1.5">
              <span class="font-mono text-[0.65rem] text-cream/80">{name}</span>
              <div class="w-[32px] h-[4px] bg-slate/15 rounded-sm overflow-hidden">
                <div class="h-full rounded-sm bg-gold/60" style={`width: ${level}%`}></div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
