---
import { cn } from '#lib/cn';

interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = '' } = Astro.props;
const g = `url(#brass-${size})`;

const cx = 32;
const cy = 32;
const angles = [0, 45, 90, 135, 180, 225, 270, 315];

function toRad(deg: number) {
  return ((deg - 90) * Math.PI) / 180;
}

function p(r: number, deg: number): string {
  const rad = toRad(deg);
  return `${(cx + r * Math.cos(rad)).toFixed(1)},${(cy + r * Math.sin(rad)).toFixed(1)}`;
}

// Spokes: from hub ring (r=8) to outer ring (r=22)
const spokesD = angles.map((a) => `M${p(8, a)} L${p(22, a)}`).join(' ');

// Handles: overlap outer ring and extend beyond (r=19 to r=31)
const handlesD = angles.map((a) => `M${p(19, a)} L${p(31, a)}`).join(' ');
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  width={size}
  height={size}
  class={cn(className)}
  aria-hidden="true"
  overflow="visible"
>
  <defs>
    <linearGradient id={`brass-${size}`} x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#D4AA3C" />
      <stop offset="45%" stop-color="#C49A2B" />
      <stop offset="100%" stop-color="#A67C1A" />
    </linearGradient>
  </defs>

  <!-- 8 spokes (behind rings for clean layering) -->
  <path d={spokesD} fill="none" stroke={g} stroke-width="2" stroke-linecap="round" />

  <!-- Outer ring (the wheel rim) -->
  <circle cx="32" cy="32" r="22" fill="none" stroke={g} stroke-width="3" />

  <!-- Inner ring (connects spokes) -->
  <circle cx="32" cy="32" r="12" fill="none" stroke={g} stroke-width="2" />

  <!-- Hub: outer ring + filled center -->
  <circle cx="32" cy="32" r="6.5" fill="none" stroke={g} stroke-width="1.5" />
  <circle cx="32" cy="32" r="3" fill={g} />

  <!-- 8 handles (on top, extend beyond outer ring) -->
  <path d={handlesD} fill="none" stroke={g} stroke-width="4" stroke-linecap="round" />
</svg>
