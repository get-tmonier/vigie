---
import WheelMark from '#components/WheelMark.astro';
---

<footer
  class="bg-navy-deep"
  style="border-top: 1px solid rgba(139, 156, 175, 0.1); padding: 1.5rem 2.5rem;"
>
  <div
    style="max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: nowrap; gap: 0.75rem;"
  >
    <!-- Left: logo + copyright -->
    <div class="footer-left" style="display: flex; align-items: center; gap: 0.6rem; white-space: nowrap;">
      <WheelMark size={16} />
      <span class="font-vollkorn-sc text-gold" style="font-weight: 700; font-size: 0.85rem; line-height: 1;"
        >Tmonier</span
      >
      <span
        class="font-mono text-slate"
        style="font-size: 0.72rem; margin-left: 0.3rem; line-height: 1;"
        >© 2026</span
      >
    </div>

    <!-- Centre: links -->
    <div style="display: flex; gap: 1.5rem; align-items: center;">
      <a
        href="/faq"
        class="font-mono text-slate"
        style="font-size: 0.75rem; text-decoration: none;"
        onmouseover="this.style.color='#C49A2B'"
        onmouseout="this.style.color='#8B9CAF'"
      >
        FAQ
      </a>
      <a
        href="/contact"
        class="font-mono text-slate"
        style="font-size: 0.75rem; text-decoration: none;"
        onmouseover="this.style.color='#C49A2B'"
        onmouseout="this.style.color='#8B9CAF'"
      >
        Contact
      </a>
    </div>

    <!-- Right: made in -->
    <span class="font-mono text-slate" style="font-size: 0.72rem; white-space: nowrap;"
      >Made in 🇧🇪</span
    >
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer {
      padding: 1rem 1.25rem !important;
    }
    .footer-left span:first-of-type {
      font-size: 0.72rem !important;
    }
    .footer-left span:last-of-type {
      font-size: 0.65rem !important;
    }
  }
</style>
