---
import WheelMark from '#components/WheelMark.astro';
---

<footer class="bg-navy-deep border-t border-slate/10 py-6 px-10">
  <div
    class="max-w-[1200px] mx-auto flex items-center justify-between flex-nowrap gap-3"
  >
    <!-- Left: logo + copyright -->
    <div class="footer-left flex items-center gap-[0.6rem] whitespace-nowrap">
      <WheelMark size={16} />
      <span class="font-vollkorn-sc text-gold font-bold text-[0.85rem] leading-none"
        >Tmonier</span
      >
      <span class="font-mono text-slate text-[0.72rem] ml-[0.3rem] leading-none"
        >© 2026</span
      >
    </div>

    <!-- Centre: links -->
    <div class="flex gap-6 items-center">
      <a
        href="/faq"
        class="font-mono text-slate text-[0.75rem] no-underline hover:text-gold transition-colors duration-200"
      >
        FAQ
      </a>
      <a
        href="/contact"
        class="font-mono text-slate text-[0.75rem] no-underline hover:text-gold transition-colors duration-200"
      >
        Contact
      </a>
    </div>

    <!-- Right: made in -->
    <span class="font-mono text-slate text-[0.72rem] whitespace-nowrap"
      >Made in 🇧🇪</span
    >
  </div>
</footer>

<style>
  @media (max-width: 768px) {
    footer {
      padding: 1rem 1.25rem;
    }
    .footer-left span:first-of-type {
      font-size: 0.72rem;
    }
    .footer-left span:last-of-type {
      font-size: 0.65rem;
    }
  }
</style>
