---
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { approach } = content;

const icons = [
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" fill="currentColor" opacity="0.2"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><line x1="12" y1="22" x2="12" y2="8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 6H7a5 5 0 0 0 0 10h10a5 5 0 0 0 0-10z"/><circle cx="7" cy="11" r="1" fill="currentColor"/><circle cx="17" cy="11" r="1" fill="currentColor"/><line x1="10" y1="11" x2="14" y2="11"/></svg>`,
];
---

<section id="approach" class="bg-cream py-20 px-10 max-md:py-12 max-md:px-5">
  <div class="max-w-[1100px] mx-auto">
    <p class="reveal-up font-mono text-gold-dark text-[0.75rem] tracking-[0.15em] uppercase m-0 mb-4" style="--delay: 0ms">
      {approach.label}
    </p>
    <h2 class="reveal-up font-bitter text-navy-deep font-bold text-[clamp(1.8rem,4vw,2.8rem)] m-0 mb-6 leading-[1.2]" style="--delay: 80ms">
      {approach.title}
    </h2>
    <p class="reveal-up font-source-serif text-navy-mid text-[1.1rem] m-0 mb-12 leading-[1.8] max-w-[700px]" style="--delay: 160ms">
      {approach.pitch}
    </p>

    <div class="grid grid-cols-3 gap-5 max-w-[1100px] max-md:grid-cols-1">
      {approach.cards.map((card, i) => (
        <div class="reveal-up" style={`--delay: ${240 + i * 120}ms`}>
          <div class="approach-card bg-navy-deep rounded-xl p-7 border border-gold/15 shadow-[0_8px_32px_rgba(0,0,0,0.15)] h-full">
            <div class="flex items-center gap-3 mb-3">
              <div class="text-gold shrink-0" set:html={icons[i]} />
              <h3 class="font-vollkorn-sc text-gold font-bold text-[1.1rem] m-0">
                {card.title}
              </h3>
            </div>
            <p class="font-source-serif text-slate text-[0.9rem] m-0 leading-[1.65]">
              {card.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .approach-card {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease, border-color 0.5s ease;
  }
  .approach-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    border-color: color-mix(in srgb, var(--gold) 30%, transparent);
  }
</style>
