---
import { cn } from '#lib/cn';

interface Props {
  title?: string;
  class?: string;
}

const { title = 'zsh', class: className } = Astro.props;
---

<div
  class={cn(
    'font-mono rounded-[10px] overflow-hidden border border-slate/15 shadow-[0_16px_48px_rgba(0,0,0,0.3)]',
    className
  )}
>
  <div class="bg-navy-mid/50 py-[0.55rem] px-[0.85rem] flex gap-[0.45rem] items-center border-b border-slate/10">
    <span class="size-[10px] rounded-full inline-block bg-signal-red"></span>
    <span class="size-[10px] rounded-full inline-block bg-signal-amber"></span>
    <span class="size-[10px] rounded-full inline-block bg-signal-green"></span>
    <span class="text-[0.6rem] text-slate/40 ml-[0.4rem]">{title}</span>
  </div>
  <div class="bg-navy-deep/60 py-4 px-5 text-[0.68rem] leading-[2]">
    <slot />
  </div>
</div>
