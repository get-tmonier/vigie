---
import AboutMe from '#components/AboutMe.astro';
import Approach from '#components/Approach.astro';
import Contact from '#components/Contact.astro';
import Experience from '#components/Experience.astro';
import FlagshipProject from '#components/FlagshipProject.astro';
import Footer from '#components/Footer.astro';
import Hero from '#components/Hero.astro';
import Nav from '#components/Nav.astro';
import TechStack from '#components/TechStack.astro';
import Base from '#layouts/Base.astro';
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
  locale: string;
}

const { content, locale } = Astro.props;
---

<Base
  title={content.meta.title}
  description={content.meta.description}
  locale={locale}
>
  <Nav locale={locale} content={content} />
  <main id="main">
    <Hero content={content} locale={locale} />
    <Approach content={content} />
    <TechStack content={content} />
    <Experience content={content} />
    <FlagshipProject content={content} />
    <AboutMe content={content} />
    <Contact content={content} locale={locale} />
  </main>
  <Footer content={content} locale={locale} />
</Base>

<style>
  /* Unified reveal animation base states */
  :global(.reveal-up),
  :global(.reveal-left),
  :global(.reveal-scale) {
    opacity: 0;
    transition-property: opacity, transform;
    transition-duration: 0.6s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(.reveal-up) {
    transform: translateY(20px);
  }
  :global(.reveal-left) {
    transform: translateX(-20px);
  }
  :global(.reveal-scale) {
    transform: scale(0.96) translateY(10px);
  }

  /* Revealed state */
  :global(.reveal-up.revealed),
  :global(.reveal-left.revealed),
  :global(.reveal-scale.revealed) {
    opacity: 1;
    transform: none;
  }

  /* Stagger delay via CSS variable */
  :global(.reveal-up),
  :global(.reveal-left),
  :global(.reveal-scale) {
    transition-delay: var(--delay, 0ms);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    :global(.reveal-up),
    :global(.reveal-left),
    :global(.reveal-scale) {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // Unified IntersectionObserver for all reveal animations
  const revealElements = document.querySelectorAll('.reveal-up, .reveal-left, .reveal-scale');

  if (revealElements.length > 0) {
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    revealElements.forEach((el) => revealObserver.observe(el));
  }
</script>
