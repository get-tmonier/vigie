---
import { Picture } from 'astro:assets';
import damienImg from '#assets/damien.jpg';
import type { SiteContent } from '../i18n/types';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { about } = content;

const birth = new Date(1994, 10, 2);
const today = new Date();
let age = today.getFullYear() - birth.getFullYear();
if (
  today.getMonth() < birth.getMonth() ||
  (today.getMonth() === birth.getMonth() && today.getDate() < birth.getDate())
) {
  age--;
}
const paragraphs = about.paragraphs.map((p) => p.replace('{{age}}', String(age)));
---

<section id="about" class="relative bg-cream py-16 px-10 max-md:py-12 max-md:px-5 overflow-hidden">
  <!-- Subtle radial glow behind photo area -->
  <div class="absolute top-1/2 left-[22%] -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-gold/[0.04] rounded-full blur-[100px] pointer-events-none max-md:left-1/2 max-md:top-[200px] max-md:w-[300px] max-md:h-[300px]"></div>

  <div class="relative max-w-[1000px] mx-auto">
    <!-- Label -->
    <p class="reveal-up font-mono text-gold-dark text-[0.75rem] tracking-[0.15em] uppercase m-0 mb-4" style="--delay: 0ms">
      {about.label}
    </p>
    <h2 class="reveal-up font-bitter text-navy-deep font-bold text-[clamp(1.8rem,4vw,2.8rem)] m-0 mb-10 leading-[1.2] max-md:mb-8" style="--delay: 80ms">
      {about.title}
    </h2>

    <!-- Two-column layout -->
    <div class="flex gap-16 items-start max-md:flex-col max-md:items-center max-md:gap-10">

      <!-- Photo column -->
      <div class="reveal-scale shrink-0 max-md:order-first" style="--delay: 160ms">
        <div class="about-photo-wrapper relative w-[220px] h-[220px] max-md:w-[180px] max-md:h-[180px]">
          <!-- Decorative ring -->
          <div class="absolute -inset-[3px] rounded-full border-2 border-navy-deep/20"></div>
          <!-- Outer glow -->
          <div class="absolute -inset-3 rounded-full bg-navy-deep/[0.06] blur-[8px]"></div>
          <!-- Photo container -->
          <div class="relative w-full h-full rounded-full overflow-hidden border-2 border-gold/30 shadow-[0_8px_32px_rgba(0,0,0,0.12)]">
            <Picture
              src={damienImg}
              alt={about.photoAlt}
              formats={['avif', 'webp']}
              widths={[220, 440]}
              sizes="(max-width: 768px) 180px, 220px"
              quality={85}
              loading="lazy"
              class="block w-full h-full object-cover scale-[1.15] origin-[center_25%]"
            />
          </div>
          <!-- Corner accent dot -->
          <div class="absolute -bottom-1 -right-1 w-4 h-4 rounded-full bg-gold shadow-[0_0_12px_rgba(212,175,55,0.4)]"></div>
        </div>

        <!-- Tags under photo -->
        <div class="flex flex-wrap gap-2 mt-6 justify-center max-w-[240px] max-md:hidden">
          {about.tags.map((tag, i) => (
            <span
              class="reveal-up font-mono text-[0.65rem] text-navy-mid border border-navy-deep/15 rounded-full px-3 py-1 whitespace-nowrap"
              style={`--delay: ${400 + i * 80}ms`}
            >
              {tag}
            </span>
          ))}
        </div>
      </div>

      <!-- Text column -->
      <div class="flex flex-col gap-5 min-w-0 max-md:text-center">
        {paragraphs.map((paragraph, i) => (
          <p
            class:list={[
              'reveal-up font-source-serif text-[1.05rem] m-0 leading-[1.85]',
              i === 0 ? 'text-navy-deep' : 'text-navy-mid',
            ]}
            style={`--delay: ${200 + i * 120}ms`}
          >
            {paragraph}
          </p>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-photo-wrapper {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .about-photo-wrapper:hover {
    transform: scale(1.04) rotate(1deg);
  }
</style>
