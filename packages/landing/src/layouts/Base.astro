---
import '#styles/global.css';

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  skipLabel?: string;
}

const {
  title = 'vigie — Open-Source AI Agent Supervision · by Tmonier',
  description = 'Local-first agent supervisor for software engineers. Real-time visibility, drift detection, token cost guardrails, checkpoints & rollback.',
  locale = 'en',
  skipLabel = 'Skip to main content',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altLocale = locale === 'fr' ? 'en' : 'fr';
const altPath =
  locale === 'fr'
    ? Astro.url.pathname.replace(/^\/fr\//, '/').replace(/^\/fr$/, '/')
    : `/fr${Astro.url.pathname === '/' ? '/' : Astro.url.pathname}`;
const altURL = new URL(altPath, Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={locale} href={canonicalURL} />
    <link rel="alternate" hreflang={altLocale} href={altURL} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-vigie-400 focus:text-navy-900 focus:font-mono focus:text-sm focus:font-semibold focus:py-2 focus:px-4 focus:rounded-[4px] focus:no-underline">
      {skipLabel}
    </a>
    <slot />
  </body>
</html>
