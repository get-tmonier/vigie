---
import '#styles/global.css';

import jbMono400 from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import sourceSerif400 from '@fontsource/source-serif-4/files/source-serif-4-latin-400-normal.woff2?url';
import vollkornSc700 from '@fontsource/vollkorn-sc/files/vollkorn-sc-latin-700-normal.woff2?url';
import vollkornSc900 from '@fontsource/vollkorn-sc/files/vollkorn-sc-latin-900-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tmonier — Your crew. Under your watch.',
  description = "You launched the agent. Now what? Tmonier shows you — in real time. When something's off, you're the one who catches it.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Tmonier',
  url: 'https://tmonier.com',
  logo: 'https://tmonier.com/favicon.svg',
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tmonier',
  url: 'https://tmonier.com',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI workflow orchestration, LLM context management, drift detection, project memory, developer tools, AI coding assistant"
    />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical above-the-fold fonts -->
    <link rel="preload" href={vollkornSc900} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={vollkornSc700} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jbMono400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={sourceSerif400} as="font" type="font/woff2" crossorigin />

    <!-- DNS prefetch for external APIs -->
    <link rel="dns-prefetch" href="https://app.loops.so" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://tmonier.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Tmonier" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://tmonier.com/og-image.png" />

    <!-- Structured data -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-gold focus:text-navy-deep focus:font-mono focus:text-sm focus:font-semibold focus:py-2 focus:px-4 focus:rounded-[4px] focus:no-underline">
      Skip to main content
    </a>
    <slot />
  </body>
</html>
