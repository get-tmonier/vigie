---
import Footer from '#components/Footer.astro';
import Nav from '#components/Nav.astro';
import Base from '#layouts/Base.astro';
---

<Base title="Page not found — Tmonier" description="The page you're looking for doesn't exist.">
  <Nav />
  <main id="main">
    <section class="bg-navy-deep min-h-[calc(100vh-64px-60px)] flex flex-col items-center justify-center px-10 text-center">
      <p class="font-mono text-[0.75rem] tracking-[0.15em] uppercase text-gold/60 m-0 mb-4">
        404
      </p>
      <h1 class="font-vollkorn-sc text-gold font-black text-[clamp(2rem,4.5vw,3rem)] m-0 mb-5 leading-[1.15]">
        Page not found
      </h1>
      <p class="font-source-serif text-slate text-[1.05rem] leading-[1.8] m-0 mb-10 max-w-[480px]">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="font-mono bg-gold text-navy-deep font-semibold text-sm py-[0.85rem] px-[1.8rem] rounded-[4px] no-underline transition-colors duration-200 inline-block hover:bg-gold-light"
      >
        Back to home
      </a>
    </section>
  </main>
  <Footer />
</Base>
