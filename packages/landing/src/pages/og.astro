---
// OG image design — open at /og, resize browser to 1200×630, screenshot → save as /public/images/og-image.png
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vollkorn+SC:wght@700;900&family=Vollkorn:wght@400;700&family=JetBrains+Mono:wght@500;600&family=Source+Serif+4:wght@400&display=swap"
      rel="stylesheet"
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 1200px; height: 630px; overflow: hidden; }
    </style>
  </head>
  <body>
    <div style="
      width: 1200px;
      height: 630px;
      background: #0B1A2E;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 72px 96px;
      overflow: hidden;
    ">

      <!-- Background glow -->
      <div style="
        position: absolute;
        top: -100px; right: -80px;
        width: 600px; height: 600px;
        background: radial-gradient(ellipse, rgba(196,154,43,0.07) 0%, transparent 65%);
        pointer-events: none;
      "></div>

      <!-- Large watermark wheel (right side) -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 64 64"
        style="position: absolute; right: 80px; top: 50%; transform: translateY(-50%); width: 340px; height: 340px; opacity: 0.07;"
      >
        <circle cx="32" cy="32" r="27" fill="none" stroke="#C49A2B" stroke-width="2.5"/>
        <circle cx="32" cy="32" r="19" fill="none" stroke="#C49A2B" stroke-width="2"/>
        <circle cx="32" cy="32" r="5.5" fill="#C49A2B"/>
        <line x1="32" y1="27" x2="32" y2="7" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="32" cy="6" rx="2.2" ry="3" fill="#C49A2B"/>
        <line x1="36.6" y1="29.8" x2="51.3" y2="15.1" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="52.6" cy="13.8" rx="2.2" ry="3" transform="rotate(45 52.6 13.8)" fill="#C49A2B"/>
        <line x1="37" y1="32" x2="57" y2="32" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="58" cy="32" rx="2.2" ry="3" transform="rotate(90 58 32)" fill="#C49A2B"/>
        <line x1="36.6" y1="34.2" x2="51.3" y2="48.9" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="52.6" cy="50.2" rx="2.2" ry="3" transform="rotate(135 52.6 50.2)" fill="#C49A2B"/>
        <line x1="32" y1="37" x2="32" y2="57" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="32" cy="58" rx="2.2" ry="3" fill="#C49A2B"/>
        <line x1="27.4" y1="34.2" x2="12.7" y2="48.9" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="11.4" cy="50.2" rx="2.2" ry="3" transform="rotate(45 11.4 50.2)" fill="#C49A2B"/>
        <line x1="27" y1="32" x2="7" y2="32" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="6" cy="32" rx="2.2" ry="3" transform="rotate(90 6 32)" fill="#C49A2B"/>
        <line x1="27.4" y1="29.8" x2="12.7" y2="15.1" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="11.4" cy="13.8" rx="2.2" ry="3" transform="rotate(135 11.4 13.8)" fill="#C49A2B"/>
      </svg>

      <!-- Brand name -->
      <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 36px;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="44" height="44">
          <defs>
            <linearGradient id="og-brass" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#D4AA3C"/>
              <stop offset="45%" stop-color="#C49A2B"/>
              <stop offset="100%" stop-color="#A67C1A"/>
            </linearGradient>
          </defs>
          <circle cx="32" cy="32" r="27" fill="none" stroke="url(#og-brass)" stroke-width="2.5"/>
          <circle cx="32" cy="32" r="19" fill="none" stroke="url(#og-brass)" stroke-width="2"/>
          <circle cx="32" cy="32" r="5.5" fill="url(#og-brass)"/>
          <line x1="32" y1="27" x2="32" y2="7" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="32" cy="6" rx="2.2" ry="3" fill="url(#og-brass)"/>
          <line x1="36.6" y1="29.8" x2="51.3" y2="15.1" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="52.6" cy="13.8" rx="2.2" ry="3" transform="rotate(45 52.6 13.8)" fill="url(#og-brass)"/>
          <line x1="37" y1="32" x2="57" y2="32" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="58" cy="32" rx="2.2" ry="3" transform="rotate(90 58 32)" fill="url(#og-brass)"/>
          <line x1="36.6" y1="34.2" x2="51.3" y2="48.9" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="52.6" cy="50.2" rx="2.2" ry="3" transform="rotate(135 52.6 50.2)" fill="url(#og-brass)"/>
          <line x1="32" y1="37" x2="32" y2="57" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="32" cy="58" rx="2.2" ry="3" fill="url(#og-brass)"/>
          <line x1="27.4" y1="34.2" x2="12.7" y2="48.9" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="11.4" cy="50.2" rx="2.2" ry="3" transform="rotate(45 11.4 50.2)" fill="url(#og-brass)"/>
          <line x1="27" y1="32" x2="7" y2="32" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="6" cy="32" rx="2.2" ry="3" transform="rotate(90 6 32)" fill="url(#og-brass)"/>
          <line x1="27.4" y1="29.8" x2="12.7" y2="15.1" stroke="url(#og-brass)" stroke-width="2.5" stroke-linecap="round"/>
          <ellipse cx="11.4" cy="13.8" rx="2.2" ry="3" transform="rotate(135 11.4 13.8)" fill="url(#og-brass)"/>
        </svg>
        <span style="
          font-family: 'Vollkorn SC', serif;
          font-weight: 900;
          font-size: 42px;
          color: #C49A2B;
          letter-spacing: 3px;
        ">Tmonier</span>
        <span style="
          font-family: 'JetBrains Mono', monospace;
          font-size: 12px;
          font-weight: 600;
          letter-spacing: 4px;
          text-transform: uppercase;
          color: rgba(139,156,175,0.5);
          align-self: center;
        ">You hold the helm.</span>
      </div>

      <!-- Main headline -->
      <h1 style="
        font-family: 'Vollkorn SC', serif;
        font-weight: 900;
        font-size: 64px;
        color: #F5F0E8;
        line-height: 1.1;
        letter-spacing: -0.01em;
        margin-bottom: 0;
      ">Your crew.<br/>Under your watch.</h1>

      <!-- Pills row -->
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        {['Real-time monitoring', 'Human-in-the-loop', 'Local-first', 'Zero markup'].map((label) => (
          <span style="
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            font-weight: 500;
            color: rgba(245,240,232,0.5);
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 4px;
            padding: 6px 14px;
          ">{label}</span>
        ))}
      </div>

      <!-- Bottom: URL -->
      <p style="
        position: absolute;
        bottom: 48px;
        left: 96px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        font-weight: 600;
        color: rgba(196,154,43,0.4);
        letter-spacing: 2px;
      ">tmonier.com</p>

      <!-- Bottom border accent -->
      <div style="
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C49A2B 30%, #C49A2B 70%, transparent);
        opacity: 0.4;
      "></div>
    </div>
  </body>
</html>
