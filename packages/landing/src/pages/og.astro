---
// OG image design — open at /og, resize browser to 1200×630, screenshot → save as /public/images/og-image.png
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Vollkorn+SC:wght@700;900&family=JetBrains+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 1200px; height: 630px; overflow: hidden; }

      .og-wrapper {
        width: 1200px;
        height: 630px;
        background: #0B1A2E;
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 72px 96px;
        overflow: hidden;
      }

      .og-watermark {
        position: absolute;
        right: 80px;
        top: 50%;
        transform: translateY(-50%);
        width: 340px;
        height: 340px;
        opacity: 0.07;
      }

      .og-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 36px;
      }

      .og-brand-name {
        font-family: 'Vollkorn SC', serif;
        font-weight: 900;
        font-size: 42px;
        color: #C49A2B;
        letter-spacing: 3px;
      }

      .og-tagline {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(139,156,175,0.5);
      }

      .og-headline {
        font-family: 'Vollkorn SC', serif;
        font-weight: 900;
        font-size: 56px;
        color: #F5F0E8;
        line-height: 1.2;
        margin-bottom: 12px;
      }

      .og-subtitle {
        font-family: 'JetBrains Mono', monospace;
        font-size: 22px;
        font-weight: 500;
        color: rgba(139,156,175,0.7);
        margin-bottom: 28px;
      }

      .og-pills {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .og-pill {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 500;
        color: rgba(245,240,232,0.5);
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 4px;
        padding: 6px 14px;
      }

      .og-url {
        position: absolute;
        bottom: 48px;
        left: 96px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        font-weight: 600;
        color: rgba(196,154,43,0.4);
        letter-spacing: 2px;
      }

      .og-border-accent {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #C49A2B 30%, #C49A2B 70%, transparent);
        opacity: 0.4;
      }
    </style>
  </head>
  <body>
    <div class="og-wrapper">
      <!-- Watermark wheel -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="og-watermark">
        <circle cx="32" cy="32" r="27" fill="none" stroke="#C49A2B" stroke-width="2.5"/>
        <circle cx="32" cy="32" r="19" fill="none" stroke="#C49A2B" stroke-width="2"/>
        <circle cx="32" cy="32" r="5.5" fill="#C49A2B"/>
        <line x1="32" y1="27" x2="32" y2="7" stroke="#C49A2B" stroke-width="2.5" stroke-linecap="round"/>
        <ellipse cx="32" cy="6" rx="2.2" ry="3" fill="#C49A2B"/>
      </svg>

      <div class="og-brand">
        <span class="og-brand-name">Tmonier</span>
        <span class="og-tagline">You Keep The Helm.</span>
      </div>

      <h1 class="og-headline">Senior Fullstack Engineer</h1>
      <p class="og-subtitle">Freelance · Brussels</p>

      <div class="og-pills">
        {['TypeScript', 'React', 'Node.js', 'Effect-TS', 'PostgreSQL'].map((label) => (
          <span class="og-pill">{label}</span>
        ))}
      </div>

      <p class="og-url">tmonier.com</p>
      <div class="og-border-accent"></div>
    </div>
  </body>
</html>
