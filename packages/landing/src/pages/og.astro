---
// OG image preview — open at /og, resize browser to 1200x630 to screenshot
import { colors, fonts, radar } from '@vigie/tokens';

const { cx, cy, outerR, middleR, innerR, centerR, rays, gradient } = radar;
const { navy900, cream50, vigie300, vigie400 } = colors;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1200" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { width: 1200px; height: 630px; overflow: hidden; }

      .og-wrapper {
        width: 1200px;
        height: 630px;
        background: radial-gradient(ellipse at 77% 50%, rgba(78,207,176,0.08) 0%, transparent 52%), #0A1628;
        position: relative;
        display: flex;
        overflow: hidden;
      }

      .og-left-bar {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
        background: #26C09A;
        opacity: 0.5;
      }

      .og-bottom-bar {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: #26C09A;
        opacity: 0.25;
      }

      .og-separator {
        position: absolute;
        left: 640px; top: 60px;
        width: 1px; height: 510px;
        background: linear-gradient(to bottom, transparent, rgba(78,207,176,0.2) 25%, rgba(78,207,176,0.2) 75%, transparent);
      }

      .og-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid rgba(78,207,176,0.1);
      }

      .og-radar {
        position: absolute;
        right: 60px;
        top: 95px;
        width: 440px;
        height: 440px;
        opacity: 0.18;
      }

      .og-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 72px 96px;
        max-width: 680px;
      }

      .og-brand {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 24px;
      }

      .og-pronunciation {
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        font-weight: 500;
        color: rgba(78,207,176,0.5);
        letter-spacing: 1px;
      }

      .og-hero-name {
        font-family: 'Instrument Serif', serif;
        font-weight: 400;
        font-size: 96px;
        color: #26C09A;
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: 16px;
      }

      .og-tagline {
        font-family: 'Instrument Serif', serif;
        font-weight: 400;
        font-style: italic;
        font-size: 30px;
        color: #FDF8F0;
        line-height: 1.3;
        margin-bottom: 28px;
      }

      .og-divider {
        width: 64px;
        height: 2px;
        background: #4ECFB0;
        opacity: 0.6;
        margin-bottom: 24px;
      }

      .og-role {
        font-family: 'JetBrains Mono', monospace;
        font-size: 16px;
        font-weight: 500;
        color: rgba(139,156,175,0.75);
        margin-bottom: 10px;
      }

      .og-sub {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 500;
        color: rgba(78,207,176,0.45);
        letter-spacing: 2px;
      }
    </style>
  </head>
  <body>
    <div class="og-wrapper">
      <div class="og-left-bar"></div>
      <div class="og-bottom-bar"></div>
      <div class="og-separator"></div>
      <div class="og-ring" style="width:580px;height:580px;left:630px;top:25px;border-color:rgba(78,207,176,0.06)"></div>
      <div class="og-ring" style="width:460px;height:460px;left:690px;top:85px;border-color:rgba(78,207,176,0.09)"></div>
      <div class="og-ring" style="width:350px;height:350px;left:745px;top:140px;border-color:rgba(78,207,176,0.12)"></div>

      <svg xmlns="http://www.w3.org/2000/svg" viewBox={radar.viewBox} class="og-radar">
        <circle cx={cx} cy={cy} r={outerR} fill="none" stroke={gradient.start} stroke-width="2.5"/>
        <circle cx={cx} cy={cy} r={middleR} fill="none" stroke={gradient.start} stroke-width="1.5"/>
        <circle cx={cx} cy={cy} r={innerR} fill="none" stroke={gradient.start} stroke-width="1"/>
        <circle cx={cx} cy={cy} r={centerR} fill={gradient.start}/>
        {rays.map((ray) => (
          <line x1={ray.x1} y1={ray.y1} x2={ray.x2} y2={ray.y2} stroke={gradient.start} stroke-width="2" stroke-linecap="round"/>
        ))}
      </svg>

      <div class="og-content">
        <div class="og-brand">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox={radar.viewBox} width="44" height="44">
            <circle cx={cx} cy={cy} r={outerR} fill="none" stroke={gradient.start} stroke-width="2.5"/>
            <circle cx={cx} cy={cy} r={middleR} fill="none" stroke={gradient.start} stroke-width="1.5"/>
            <circle cx={cx} cy={cy} r={innerR} fill="none" stroke={gradient.start} stroke-width="1"/>
            <circle cx={cx} cy={cy} r={centerR} fill={gradient.start}/>
            {rays.map((ray) => (
              <line x1={ray.x1} y1={ray.y1} x2={ray.x2} y2={ray.y2} stroke={gradient.start} stroke-width="2" stroke-linecap="round"/>
            ))}
          </svg>
          <span class="og-pronunciation">/vi.ʒi/</span>
        </div>
        <div class="og-hero-name">vigie</div>
        <div class="og-tagline">Eyes on the horizon.</div>
        <div class="og-divider"></div>
        <div class="og-role">AI Agent Supervision</div>
        <div class="og-sub">Open Source · Local-First</div>
      </div>
    </div>
  </body>
</html>
