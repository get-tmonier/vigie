---
import Footer from '#components/Footer.astro';
import Nav from '#components/Nav.astro';
import Base from '#layouts/Base.astro';
import fr from '../../i18n/fr';

const { contactPage } = fr;
---

<Base
  title={contactPage.title}
  description={contactPage.subtitle}
  locale="fr"
>
  <Nav locale="fr" content={fr} currentPage="contact" />
  <main id="main">
    <!-- Mini hero -->
    <section class="bg-navy-deep pt-20 px-10 pb-12 text-center max-md:pt-12 max-md:px-5 max-md:pb-8">
      <div class="max-w-[720px] mx-auto">
        <p class="font-mono text-[0.75rem] tracking-[0.15em] uppercase text-gold/80 m-0 mb-4">
          {contactPage.heading}
        </p>
        <h1 class="font-vollkorn-sc text-gold font-black text-[clamp(2rem,4.5vw,3rem)] m-0 mb-5 leading-[1.15]">
          {contactPage.heading}
        </h1>
        <p class="font-source-serif text-slate text-[1.05rem] leading-[1.8] m-0 max-w-[520px] mx-auto">
          {contactPage.subtitle}
        </p>
      </div>
    </section>

    <!-- Form -->
    <section class="bg-navy-deep px-10 pb-24 max-md:px-5 max-md:pb-16 max-md:pt-0">
      <div class="max-w-[600px] mx-auto">
        <form
          id="contact-form"
          action="mailto:damien.meur@tmonier.com"
          method="POST"
          enctype="text/plain"
          class="flex flex-col gap-5"
        >
          <div class="field-group">
            <label
              for="contact-name"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/80 block mb-2"
            >
              {contactPage.nameLabel}
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              placeholder={contactPage.namePlaceholder}
              autocomplete="name"
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border transition-colors duration-200 focus:border-gold/60 placeholder:text-slate/50"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-email"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/80 block mb-2"
            >
              {contactPage.emailLabel}
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              placeholder={contactPage.emailPlaceholder}
              autocomplete="email"
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border transition-colors duration-200 focus:border-gold/60 placeholder:text-slate/50"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-subject"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/80 block mb-2"
            >
              {contactPage.subjectLabel}
            </label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border cursor-pointer appearance-none transition-colors duration-200 focus:border-gold/60"
            >
              <option value="" disabled selected class="bg-navy-deep text-slate">{contactPage.subjectPlaceholder}</option>
              {contactPage.subjectOptions.map((opt) => (
                <option value={opt.value} class="bg-navy-deep">{opt.label}</option>
              ))}
            </select>
          </div>

          <div class="field-group">
            <label
              for="contact-message"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/80 block mb-2"
            >
              {contactPage.messageLabel}
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="6"
              placeholder={contactPage.messagePlaceholder}
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border resize-y leading-[1.6] transition-colors duration-200 focus:border-gold/60 placeholder:text-slate/50"
            ></textarea>
          </div>

          <button
            type="submit"
            class="font-mono bg-gold text-navy-deep font-semibold text-sm border-none rounded-[4px] py-[0.9rem] px-8 cursor-pointer self-start transition-colors duration-200 hover:bg-gold-light"
          >
            {contactPage.submit}
          </button>
        </form>

        <p class="font-mono text-[0.72rem] text-slate/50 mt-8 leading-[1.6]">
          {contactPage.altText} <a
            href="mailto:damien.meur@tmonier.com"
            class="text-gold/80 no-underline hover:text-gold transition-colors duration-200"
          >damien.meur@tmonier.com</a>
        </p>
      </div>
    </section>
  </main>
  <Footer content={fr} locale="fr" />
</Base>
