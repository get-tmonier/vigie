---
import Base from '#layouts/Base.astro';
import Nav from '#components/Nav.astro';
import Footer from '#components/Footer.astro';
---

<Base
  title="Contact — Tmonier"
  description="Get in touch with the Tmonier team. We'd love to hear from you."
>
  <Nav currentPage="contact" />
  <main>
    <!-- Mini hero -->
    <section class="bg-navy-deep pt-20 px-10 pb-12 text-center">
      <div class="max-w-[720px] mx-auto">
        <p class="font-mono text-[0.75rem] tracking-[0.15em] uppercase text-gold/60 m-0 mb-4">
          Get in touch
        </p>
        <h1 class="font-vollkorn-sc text-gold font-black text-[clamp(2rem,4.5vw,3rem)] m-0 mb-5 leading-[1.15]">
          Contact us
        </h1>
        <p class="font-source-serif text-slate text-[1.05rem] leading-[1.8] m-0 max-w-[520px] mx-auto">
          A question, a bug, or just want to say hi? We read every message and reply within 24 hours.
        </p>
      </div>
    </section>

    <!-- Form -->
    <section class="bg-navy-deep px-10 pb-24">
      <div class="max-w-[600px] mx-auto">
        <form
          id="contact-form"
          action="mailto:support@tmonier.com"
          method="POST"
          enctype="text/plain"
          class="flex flex-col gap-5"
        >
          <div class="field-group">
            <label
              for="contact-name"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/60 block mb-2"
            >
              Name
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              autocomplete="name"
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border transition-colors duration-200 focus:border-gold/60"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-email"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/60 block mb-2"
            >
              Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              placeholder="your@email.com"
              autocomplete="email"
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border transition-colors duration-200 focus:border-gold/60"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-subject"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/60 block mb-2"
            >
              Subject
            </label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border cursor-pointer appearance-none transition-colors duration-200 focus:border-gold/60"
            >
              <option value="" disabled selected class="contact-option contact-option--placeholder">Select a topic…</option>
              <option value="General question" class="contact-option">General question</option>
              <option value="Bug report" class="contact-option">Bug report</option>
              <option value="Enterprise inquiry" class="contact-option">Enterprise inquiry</option>
              <option value="Press & partnerships" class="contact-option">Press & partnerships</option>
              <option value="Other" class="contact-option">Other</option>
            </select>
          </div>

          <div class="field-group">
            <label
              for="contact-message"
              class="font-mono text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-gold/60 block mb-2"
            >
              Message
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="6"
              placeholder="Tell us what's on your mind…"
              class="contact-input font-mono text-cream w-full text-sm bg-navy-mid/50 border border-gold/20 rounded-[4px] py-[0.85rem] px-4 outline-none box-border resize-y leading-[1.6] transition-colors duration-200 focus:border-gold/60"
            ></textarea>
          </div>

          <button
            type="submit"
            class="font-mono bg-gold text-navy-deep font-semibold text-sm border-none rounded-[4px] py-[0.9rem] px-8 cursor-pointer self-start transition-colors duration-200 hover:bg-gold-light"
          >
            Send message
          </button>
        </form>

        <p class="font-mono text-[0.72rem] text-slate/50 mt-8 leading-[1.6]">
          Or reach us directly at <a
            href="mailto:support@tmonier.com"
            class="text-gold/60 no-underline hover:text-gold transition-colors duration-200"
          >support@tmonier.com</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  @media (max-width: 768px) {
    section:first-of-type {
      padding: 3rem 1.25rem 2rem;
    }
    section:last-of-type {
      padding: 0 1.25rem 4rem;
    }
  }

  ::placeholder {
    color: color-mix(in srgb, var(--slate) 40%, transparent);
  }

  .contact-option {
    background: var(--navy-deep);
  }

  .contact-option--placeholder {
    color: var(--slate);
  }
</style>
