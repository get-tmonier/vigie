---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Contact — Tmonier"
  description="Get in touch with the Tmonier team. We'd love to hear from you."
>
  <Nav currentPage="contact" />
  <main>
    <!-- Mini hero -->
    <section style="background: #0B1A2E; padding: 5rem 2.5rem 3rem; text-align: center;">
      <div style="max-width: 720px; margin: 0 auto;">
        <p
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(196, 154, 43, 0.6); margin: 0 0 1rem;"
        >
          Get in touch
        </p>
        <h1
          style="font-family: 'Vollkorn SC', serif; font-weight: 900; font-size: clamp(2rem, 4.5vw, 3rem); color: #C49A2B; margin: 0 0 1.25rem; line-height: 1.15;"
        >
          Contact us
        </h1>
        <p
          style="font-family: 'Source Serif 4', serif; font-size: 1.05rem; color: #8B9CAF; line-height: 1.8; margin: 0; max-width: 520px; margin-left: auto; margin-right: auto;"
        >
          A question, a bug, or just want to say hi? We read every message and reply within 24 hours.
        </p>
      </div>
    </section>

    <!-- Form -->
    <section style="background: #0B1A2E; padding: 0 2.5rem 6rem;">
      <div style="max-width: 600px; margin: 0 auto;">
        <form
          id="contact-form"
          action="mailto:support@tmonier.com"
          method="POST"
          enctype="text/plain"
          style="display: flex; flex-direction: column; gap: 1.25rem;"
        >
          <div class="field-group">
            <label
              for="contact-name"
              style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(196, 154, 43, 0.6); display: block; margin-bottom: 0.5rem;"
            >
              Name
            </label>
            <input
              id="contact-name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              autocomplete="name"
              class="contact-input"
              style="width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; background: rgba(29, 53, 87, 0.5); border: 1px solid rgba(196, 154, 43, 0.2); border-radius: 4px; color: #F5F0E8; padding: 0.85rem 1rem; outline: none; box-sizing: border-box; transition: border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(196,154,43,0.6)'"
              onblur="this.style.borderColor='rgba(196,154,43,0.2)'"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-email"
              style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(196, 154, 43, 0.6); display: block; margin-bottom: 0.5rem;"
            >
              Email
            </label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              placeholder="your@email.com"
              autocomplete="email"
              class="contact-input"
              style="width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; background: rgba(29, 53, 87, 0.5); border: 1px solid rgba(196, 154, 43, 0.2); border-radius: 4px; color: #F5F0E8; padding: 0.85rem 1rem; outline: none; box-sizing: border-box; transition: border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(196,154,43,0.6)'"
              onblur="this.style.borderColor='rgba(196,154,43,0.2)'"
            />
          </div>

          <div class="field-group">
            <label
              for="contact-subject"
              style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(196, 154, 43, 0.6); display: block; margin-bottom: 0.5rem;"
            >
              Subject
            </label>
            <select
              id="contact-subject"
              name="subject"
              required
              class="contact-input"
              style="width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; background: rgba(29, 53, 87, 0.5); border: 1px solid rgba(196, 154, 43, 0.2); border-radius: 4px; color: #F5F0E8; padding: 0.85rem 1rem; outline: none; box-sizing: border-box; cursor: pointer; appearance: none; transition: border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(196,154,43,0.6)'"
              onblur="this.style.borderColor='rgba(196,154,43,0.2)'"
            >
              <option value="" disabled selected style="background: #0B1A2E; color: #8B9CAF;">Select a topic…</option>
              <option value="General question" style="background: #0B1A2E;">General question</option>
              <option value="Bug report" style="background: #0B1A2E;">Bug report</option>
              <option value="Enterprise inquiry" style="background: #0B1A2E;">Enterprise inquiry</option>
              <option value="Press & partnerships" style="background: #0B1A2E;">Press & partnerships</option>
              <option value="Other" style="background: #0B1A2E;">Other</option>
            </select>
          </div>

          <div class="field-group">
            <label
              for="contact-message"
              style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(196, 154, 43, 0.6); display: block; margin-bottom: 0.5rem;"
            >
              Message
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="6"
              placeholder="Tell us what's on your mind…"
              class="contact-input"
              style="width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; background: rgba(29, 53, 87, 0.5); border: 1px solid rgba(196, 154, 43, 0.2); border-radius: 4px; color: #F5F0E8; padding: 0.85rem 1rem; outline: none; box-sizing: border-box; resize: vertical; line-height: 1.6; transition: border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(196,154,43,0.6)'"
              onblur="this.style.borderColor='rgba(196,154,43,0.2)'"
            ></textarea>
          </div>

          <button
            type="submit"
            style="font-family: 'JetBrains Mono', monospace; font-weight: 600; font-size: 0.875rem; background: #C49A2B; color: #0B1A2E; border: none; border-radius: 4px; padding: 0.9rem 2rem; cursor: pointer; align-self: flex-start; transition: background 0.2s;"
            onmouseover="this.style.background='#D4AA3C'"
            onmouseout="this.style.background='#C49A2B'"
          >
            Send message
          </button>
        </form>

        <p
          style="font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(139, 156, 175, 0.5); margin: 2rem 0 0; line-height: 1.6;"
        >
          Or reach us directly at <a
            href="mailto:support@tmonier.com"
            style="color: rgba(196, 154, 43, 0.6); text-decoration: none;"
            onmouseover="this.style.color='#C49A2B'"
            onmouseout="this.style.color='rgba(196,154,43,0.6)'"
          >support@tmonier.com</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  @media (max-width: 768px) {
    section:first-of-type {
      padding: 3rem 1.25rem 2rem !important;
    }
    section:last-of-type {
      padding: 0 1.25rem 4rem !important;
    }
  }

  ::placeholder {
    color: rgba(139, 156, 175, 0.4);
  }
</style>
