{
  "name": "@tmonier/landing",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*",
    "#layouts/*": "./src/layouts/*",
    "#assets/*": "./src/assets/*",
    "#styles/*": "./src/styles/*",
    "#lib/*": "./src/lib/*"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bun scripts/gen-favicon.mjs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.0",
    "@fontsource/bitter": "5.2.10",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/source-serif-4": "5.2.9",
    "@fontsource/vollkorn": "5.2.10",
    "@fontsource/vollkorn-sc": "5.2.8",
    "@tailwindcss/vite": "4.2.1",
    "@tmonier/tokens": "workspace:*",
    "astro": "6.0.0-beta.17",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.6",
    "@resvg/resvg-js": "2.6.2",
    "satori": "0.19.2",
    "sharp": "0.34.5",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
