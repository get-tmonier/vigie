{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowArbitraryExtensions": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun-types", "react", "react-dom"],
    "paths": {
      "#modules/*": ["./src/modules/*"],
      "#shell/*": ["./src/shell/*"],
      "#shared/*": ["./src/shared/*"],
      "#dependencies": ["./src/dependencies.ts"]
    },
    "plugins": [
      {
        "name": "@effect/tsgo",
        "diagnosticSeverity": {
          "preferSchemaOverJson": "off"
        }
      }
    ]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
