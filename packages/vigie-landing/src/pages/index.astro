---
import Base from '#layouts/Base.astro';
---

<Base>
  <main id="main">
    <section class="min-h-screen flex flex-col items-center justify-center px-10 text-center">
      <h1 class="font-vollkorn-sc text-gold font-black text-[clamp(2.2rem,4.5vw,3.2rem)] m-0 mb-5 leading-[1.15]">
        Vigie
      </h1>
      <p class="font-mono text-slate text-sm m-0 mb-8">
        AI Agent Supervision — Coming soon
      </p>
      <a
        href="https://tmonier.com"
        class="font-mono text-gold/80 text-[0.8rem] no-underline hover:text-gold transition-colors duration-200"
      >
        &larr; tmonier.com
      </a>
    </section>
  </main>
</Base>
