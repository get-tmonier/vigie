---
const availableTools = ['Claude Code'];
---

<section class="bg-navy-deep py-5 px-10 border-t border-b border-gold/8">
  <div class="max-w-[1200px] mx-auto">
    <div class="flex items-center gap-4 flex-wrap">
      <p class="font-mono text-[0.68rem] tracking-[3px] text-slate/45 uppercase whitespace-nowrap shrink-0 m-0 min-w-[6rem]">
        Your AI
      </p>
      <div class="flex gap-[0.6rem] flex-wrap items-center">
        {availableTools.map((t) => (
          <span class="font-mono text-[0.72rem] font-medium text-cream/85 bg-gold/10 border border-gold/25 rounded-[4px] py-[0.3rem] px-[0.7rem] whitespace-nowrap">
            {t}
          </span>
        ))}
        <span class="font-mono text-[0.65rem] text-slate/40 pl-1">
          Coming soon: OpenCode <span class="text-gold/50">&#9679;</span> supports Copilot license since Jan 2026 <span class="pl-2 text-slate/30">|</span><span class="pl-2">Codex, Aider, Cline & more</span>
        </span>
      </div>
    </div>
  </div>
</section>
