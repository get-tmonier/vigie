{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "#modules/*": ["./src/modules/*"],
      "#schemas/*": ["./src/schemas/*"],
      "#terminal/*": ["./src/terminal/*"],
      "#vterm/*": ["./src/vterm/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
