{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["bun-types", "react", "react-dom"],
    "paths": {
      "#modules/*": ["./src/modules/*"],
      "#lib/*": ["./src/lib/*"],
      "#infra/*": ["./src/infra/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
