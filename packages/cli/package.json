{
  "name": "@vigie/app",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "vigie": "./dist/index.js"
  },
  "imports": {
    "#modules/*": "./src/modules/*",
    "#lib/*": "./src/lib/*",
    "#infra/*": "./src/infra/*"
  },
  "scripts": {
    "dev": "VIGIE_DEV=true bun run --watch src/modules/daemon/main.ts",
    "dev:claude": "bun run src/cli.ts claude",
    "build:pty": "sh scripts/build-pty.sh",
    "build:ui": "cd ../ui && bun run build && cp -r dist ../../packages/cli/dist/ui-dist",
    "build": "bun run build:pty && bun build --compile --target=bun src/cli.ts --outfile dist/vigie && bun run build:ui",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "test": "bun test"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.24",
    "@xterm/headless": "5.5.0",
    "effect": "4.0.0-beta.24",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3"
  }
}
