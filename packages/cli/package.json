{
  "name": "@vigie/cli",
  "version": "0.3.0",
  "type": "module",
  "bin": {
    "vigie": "./dist/index.js"
  },
  "imports": {
    "#modules/*": "./src/modules/*",
    "#schemas/*": "./src/schemas/*",
    "#terminal/*": "./src/terminal/*",
    "#vterm/*": "./src/vterm/*"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "dev:claude": "bun run src/cli.ts claude",
    "dev:daemon": "bun run src/modules/daemon/main.ts",
    "build:pty": "sh scripts/build-pty.sh",
    "build": "bun run build:pty && bun build --compile --target=bun src/cli.ts --outfile dist/vigie",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "test": "bun test"
  },
  "dependencies": {
    "@effect/platform-bun": "4.0.0-beta.24",
    "@xterm/headless": "5.5.0",
    "effect": "4.0.0-beta.24",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
