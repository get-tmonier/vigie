{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "#app/*": ["./src/app/*"],
      "#entities/*": ["./src/entities/*"],
      "#features/*": ["./src/features/*"],
      "#pages/*": ["./src/pages/*"],
      "#routes/*": ["./src/routes/*"],
      "#shared/*": ["./src/shared/*"],
      "#widgets/*": ["./src/widgets/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", ".output"]
}
