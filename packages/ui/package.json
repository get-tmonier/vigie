{
  "name": "@tmonier/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./src/app/*",
    "#entities/*": "./src/entities/*",
    "#features/*": "./src/features/*",
    "#pages/*": "./src/pages/*",
    "#routes/*": "./src/routes/*",
    "#shared/*": "./src/shared/*",
    "#widgets/*": "./src/widgets/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "bun .output/server/index.mjs",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --write ./src",
    "format": "biome format --write ./src",
    "format:fix": "biome format --write ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check-imports": "bun ../../scripts/check-imports.ts",
    "fix-imports": "bun ../../scripts/fix-imports.ts"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/source-serif-4": "5.2.9",
    "@fontsource/vollkorn": "5.2.10",
    "@fontsource/vollkorn-sc": "5.2.8",
    "@tanstack/react-router": "1.163.3",
    "@tanstack/react-start": "1.164.0",
    "@better-auth/api-key": "1.5.1",
    "better-auth": "1.5.1",
    "@tmonier/shared": "workspace:*",
    "@tmonier/tokens": "workspace:*",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-router-devtools": "1.163.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
