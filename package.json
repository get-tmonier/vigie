{
  "name": "tmonier",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "trustedDependencies": [
    "sharp",
    "workerd"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@tmonier/api --filter=@tmonier/ui",
    "dev:landing": "turbo run dev --filter=@tmonier/landing",
    "dev:all": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "check": "turbo run check",
    "check:fix": "turbo run check:fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "bump": "ncu --workspaces --root -u && bun install",
    "bump:check": "ncu --workspaces --root",
    "knip": "knip",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "bun biome check --staged --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "knip": "^5.85.0",
    "npm-check-updates": "19.6.3",
    "simple-git-hooks": "^2.13.1",
    "turbo": "2.8.12"
  },
  "packageManager": "bun@1.3.10"
}
