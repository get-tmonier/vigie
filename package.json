{
  "name": "@tmonier/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": { "tmonier": "./dist/index.js" },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --target=bun src/index.ts --outfile dist/tmonier",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
